<div class="space-y-6">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100"><%= title %></h3>
      <p class="mt-1 text-sm text-slate-600 dark:text-slate-400"><%= description %></p>
    </div>
    <% if defined?(badge_text) && badge_text.present? %>
      <span class="inline-flex rounded-full <%= badge_classes %> px-3 py-1 text-xs font-semibold uppercase tracking-wide"><%= badge_text %></span>
    <% end %>
  </div>

  <% MedicalSupplyItem::CATEGORY_ORDER.each do |category| %>
    <% items = items_by_category[category] || [] %>
    <section class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow dark:border-slate-700 dark:bg-slate-800">
      <div class="border-b border-slate-200 bg-slate-50/80 px-5 py-4 dark:border-slate-700 dark:bg-slate-900/40">
        <div class="flex items-center justify-between gap-3">
          <div>
            <h4 class="text-base font-semibold text-slate-900 dark:text-slate-100"><%= category %></h4>
            <p class="mt-1 text-xs text-slate-500 dark:text-slate-400"><%= category_hints[category] %></p>
          </div>
          <div class="flex items-center gap-2">
            <% if local_assigns[:print_path_builder].present? %>
              <%= link_to "Druckansicht", print_path_builder.call(category), target: "_blank", rel: "noreferrer", class: "inline-flex rounded-lg border border-slate-300 px-3 py-1.5 text-xs font-medium text-slate-700 hover:bg-slate-100 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-700" %>
            <% end %>
            <span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs font-medium text-slate-600 dark:bg-slate-900/60 dark:text-slate-300"><%= pluralize(items.size, "Eintrag", "Einträge") %></span>
          </div>
        </div>
      </div>

      <div class="overflow-x-auto">
        <div class="min-w-[72rem] text-center">
          <div class="grid grid-cols-[11.5rem_minmax(0,1.4fr)_5rem_7rem_minmax(0,1.2fr)_2.5rem_2.5rem_11rem] gap-3 border-b border-slate-200 bg-slate-50 px-4 py-3 text-xs font-semibold uppercase tracking-wide text-slate-600 dark:border-slate-700 dark:bg-slate-900/40 dark:text-slate-300">
            <div>Verwendungszweck</div>
            <div>Artikel</div>
            <div>Menge</div>
            <div>Ablauf</div>
            <div>Anmerkungen</div>
            <div>Fehlt</div>
            <div>Angebr.</div>
            <div>Aktionen</div>
          </div>

          <div class="divide-y divide-slate-200 dark:divide-slate-700">
            <% if items.any? %>
              <% items.each do |item| %>
                <% if can_manage %>
                  <%= form_with model: item, url: item_path_builder.call(item), method: :patch, class: "grid grid-cols-[auto_minmax(0,1.4fr)_5rem_7rem_minmax(0,1.2fr)_2.5rem_2.5rem_auto] gap-3 px-4 py-3" do |f| %>
                    <%= f.hidden_field :category, value: item.category %>
                    <div>
                      <%= f.text_field :usage_purpose, placeholder: "optional", class: "w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 outline-none transition focus:border-red-600 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
                    </div>
                    <div>
                      <%= f.text_field :name, class: "w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 outline-none transition focus:border-red-600 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
                    </div>
                    <div>
                      <%= f.text_field :quantity, placeholder: "z. B. 2x", class: "w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 outline-none transition focus:border-red-600 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
                    </div>
                    <div>
                      <%= f.text_field :expires_on_label, placeholder: "z. B. 10.2026", class: "w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 outline-none transition focus:border-red-600 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
                    </div>
                    <div>
                      <%= f.text_field :notes, placeholder: "z. B. Gültig bis..., Nachkaufen", class: "w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 outline-none transition focus:border-red-600 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
                    </div>
                    <label class="inline-flex items-center justify-center gap-2 rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-700 dark:border-slate-600 dark:text-slate-300">
                      <%= f.check_box :missing, class: "rounded border-slate-300 text-red-600 focus:ring-red-500 dark:border-slate-600 dark:bg-slate-900" %>
                    </label>
                    <label class="inline-flex items-center justify-center gap-2 rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-700 dark:border-slate-600 dark:text-slate-300">
                      <%= f.check_box :opened, class: "rounded border-slate-300 text-red-600 focus:ring-red-500 dark:border-slate-600 dark:bg-slate-900" %>
                    </label>
                    <div class="flex justify-end gap-2">
                      <%= f.submit "Speichern", class: "inline-flex rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-700" %>
                      <%= link_to "Löschen", item_path_builder.call(item), data: { turbo_method: :delete, turbo_confirm: "Eintrag wirklich löschen?" }, class: "inline-flex rounded-lg bg-red-600 px-3 py-2 text-sm font-medium text-white hover:bg-red-700" %>
                    </div>
                  <% end %>
                <% else %>
                  <div class="grid grid-cols-[10rem_10rem_minmax(0,1.4fr)_10rem_minmax(0,1.2fr)_5.5rem_7rem] gap-3 px-4 py-3 text-sm">
                    <div class="text-slate-700 dark:text-slate-300"><%= item.usage_purpose.presence || "—" %></div>
                    <div class="font-medium text-slate-900 dark:text-slate-100"><%= item.name %></div>
                    <div class="text-slate-700 dark:text-slate-300"><%= item.quantity.presence || "—" %></div>
                    <div class="text-slate-700 dark:text-slate-300"><%= item.expires_on_label.presence || "—" %></div>
                    <div class="text-slate-700 dark:text-slate-300"><%= item.notes.presence || "—" %></div>
                    <div>
                      <% if item.missing? %>
                        <span class="inline-flex rounded-full bg-red-100 px-2 py-1 text-xs font-semibold text-red-700 dark:bg-red-900/60 dark:text-red-200">Ja</span>
                      <% else %>
                        <span class="text-slate-400 dark:text-slate-500">—</span>
                      <% end %>
                    </div>
                    <div>
                      <% if item.opened? %>
                        <span class="inline-flex rounded-full bg-amber-100 px-2 py-1 text-xs font-semibold text-amber-700 dark:bg-amber-900/60 dark:text-amber-200">Ja</span>
                      <% else %>
                        <span class="text-slate-400 dark:text-slate-500">—</span>
                      <% end %>
                    </div>
                  </div>
                <% end %>
              <% end %>
            <% else %>
              <div class="px-4 py-6 text-sm text-slate-500 dark:text-slate-400">Noch keine Einträge in dieser Kategorie.</div>
            <% end %>
          </div>
        </div>
      </div>

      <% if can_manage %>
        <div class="border-t border-slate-200 bg-slate-50/50 px-4 py-4 dark:border-slate-700 dark:bg-slate-900/20">
          <%= form_with model: MedicalSupplyItem.new(category: category), url: create_url, class: "grid gap-3 lg:grid-cols-[10rem_minmax(0,1.4fr)_10rem_10rem_minmax(0,1.2fr)_5.5rem_7rem_auto]" do |f| %>
            <%= f.hidden_field :category, value: category %>
            <div>
              <%= f.label :usage_purpose, "Verwendungszweck", class: "mb-1 block text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400" %>
              <%= f.text_field :usage_purpose, placeholder: "optional", class: "w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 outline-none transition focus:border-red-600 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
            </div>
            <div>
              <%= f.label :name, "Artikel", class: "mb-1 block text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400" %>
              <%= f.text_field :name, placeholder: "z. B. Paracetamol", class: "w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 outline-none transition focus:border-red-600 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
            </div>
            <div>
              <%= f.label :quantity, "Menge", class: "mb-1 block text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400" %>
              <%= f.text_field :quantity, placeholder: "z. B. 2x", class: "w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 outline-none transition focus:border-red-600 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
            </div>
            <div>
              <%= f.label :expires_on_label, "Ablauf", class: "mb-1 block text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400" %>
              <%= f.text_field :expires_on_label, placeholder: "z. B. 10.2026", class: "w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 outline-none transition focus:border-red-600 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
            </div>
            <div>
              <%= f.label :notes, "Anmerkungen", class: "mb-1 block text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400" %>
              <%= f.text_field :notes, placeholder: "z. B. Gültig bis..., Nachkaufen", class: "w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 outline-none transition focus:border-red-600 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
            </div>
            <label class="mt-6 inline-flex items-center justify-center gap-2 rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-700 dark:border-slate-600 dark:text-slate-300">
              <%= f.check_box :missing, class: "rounded border-slate-300 text-red-600 focus:ring-red-500 dark:border-slate-600 dark:bg-slate-900" %>
              <span>Fehlt</span>
            </label>
            <label class="mt-6 inline-flex items-center justify-center gap-2 rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-700 dark:border-slate-600 dark:text-slate-300">
              <%= f.check_box :opened, class: "rounded border-slate-300 text-red-600 focus:ring-red-500 dark:border-slate-600 dark:bg-slate-900" %>
              <span>Angebr.</span>
            </label>
            <div class="flex items-end justify-end">
              <%= f.submit "Eintrag hinzufügen", class: "inline-flex rounded-lg bg-red-600 px-4 py-2.5 text-sm font-medium text-white hover:bg-red-700" %>
            </div>
          <% end %>
        </div>
      <% end %>
    </section>
  <% end %>

  <% if show_history %>
    <div class="rounded-2xl border border-slate-200 bg-slate-50/70 p-4 dark:border-slate-700 dark:bg-slate-900/30">
      <h4 class="text-sm font-semibold text-slate-900 dark:text-slate-100">Änderungsverlauf</h4>
      <div class="mt-3 space-y-2">
        <% if changes.any? %>
          <% changes.each do |change| %>
            <div class="rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm dark:border-slate-700 dark:bg-slate-900/60">
              <div class="flex flex-wrap items-center justify-between gap-2 text-xs text-slate-500 dark:text-slate-400">
                <span><%= l(change.created_at, format: "%d.%m.%Y %H:%M") %></span>
                <span><%= change.actor_name %></span>
              </div>
              <p class="mt-1 font-medium text-slate-900 dark:text-slate-100"><%= change.item_name %></p>
              <p class="mt-1 text-slate-600 dark:text-slate-300"><%= change.change_summary %></p>
            </div>
          <% end %>
        <% else %>
          <p class="text-sm text-slate-500 dark:text-slate-400">Noch keine Änderungen protokolliert.</p>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
