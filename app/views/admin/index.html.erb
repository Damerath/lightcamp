<div class="space-y-8">
  <div>
    <h2 class="text-2xl font-bold">Adminbereich</h2>
    <p class="mt-1 text-slate-600 dark:text-slate-400">
      Hier findest alle Adminwerkzeuge.
    </p>
  </div>

  <div class="space-y-6">
    <div>
      <div class="grid gap-4 sm:grid-cols-2">
        <%= link_to users_path, class: "block rounded-lg bg-white p-5 shadow hover:ring-1 hover:ring-blue-400 dark:bg-slate-800" do %>
          <h4 class="font-semibold text-slate-900 dark:text-slate-100">
            Benutzerverwaltung
          </h4>
          <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
            Verwalte alle Benutzer des Systems.
          </p>
        <% end %>

        <div class="block rounded-lg bg-white p-5 shadow hover:ring-1 hover:ring-blue-400 dark:bg-slate-800">
          <h4 class="font-semibold text-slate-900 dark:text-slate-100">
            Campverwaltung
          </h4>
          <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
            Verwalte alle Camps für jedes Jahr.
          </p>
          <div class="mt-4">
            <%= link_to admin_camps_path, class: "inline-flex rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-100 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-700" do %>
              Camps einrichten
            <% end %>
            <%= link_to admin_camp_applications_path, class: "inline-flex rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-100 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-700" do %>
              Mitarbeiter zuteilen
            <% end %>
            <%= link_to admin_camp_teams_path(1), class: "inline-flex rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-100 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-700" do %>
              Teamview
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>