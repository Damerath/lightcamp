<div class="space-y-6">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h2 class="text-2xl font-bold">Benutzerverwaltung</h2>
      <p class="mt-1 text-slate-600 dark:text-slate-400">
        Hier kannst du Rollen verwalten und Benutzer löschen.
      </p>
    </div>

    <%= link_to "Zur Admin-Übersicht", admin_path, class: "inline-flex rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-700" %>
  </div>

  <div class="space-y-3">
    <% @users.each do |user| %>
      <%= link_to users_path(modal: "edit_user", user_id: user.id), class: "grid grid-cols-[1.2fr_1.4fr_auto] items-center gap-4 rounded-lg bg-white p-5 shadow transition hover:ring-1 hover:ring-blue-400 dark:bg-slate-800" do %>
        <div>
          <p class="font-semibold text-slate-900 dark:text-slate-100">
            <%= [user.first_name, user.last_name].compact.join(" ").presence || user.email %>
          </p>
        </div>

        <p class="text-sm text-slate-600 dark:text-slate-400">
          <%= user.email %>
        </p>

        <span class="justify-self-start rounded-full px-2.5 py-1 text-xs font-medium <%= user.admin? ? 'bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-200' : 'bg-slate-100 text-slate-700 dark:bg-slate-700 dark:text-slate-200' %>">
          <%= user.role %>
        </span>
      <% end %>
    <% end %>
  </div>

  <% if params[:modal] == "edit_user" && @selected_user %>
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 px-4 backdrop-blur-sm">
      <div class="w-full max-w-md rounded-2xl bg-white p-6 shadow-xl dark:bg-slate-800">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h3 class="text-xl font-bold text-slate-900 dark:text-slate-100">Benutzer bearbeiten</h3>
            <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
              <%= [@selected_user.first_name, @selected_user.last_name].compact.join(" ").presence || @selected_user.email %>
            </p>
            <p class="text-sm text-slate-500 dark:text-slate-400">
              <%= @selected_user.email %>
            </p>
          </div>

          <%= link_to "×", users_path, class: "text-2xl leading-none text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white" %>
        </div>

        <%= form_with model: @selected_user, url: user_path(@selected_user), method: :patch, class: "mt-6 space-y-5" do |f| %>
          <div>
            <%= f.label :role, "Rolle", class: "mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300" %>
            <%= f.select :role, options_for_select([["user", "user"], ["admin", "admin"]], @selected_user.role), {}, class: "w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-slate-900 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
          </div>

          <div class="flex justify-between gap-3 pt-2">
            <%= link_to "Benutzer loeschen", user_path(@selected_user), data: { turbo_method: :delete, turbo_confirm: "Willst du diesen Benutzer wirklich loeschen?" }, class: "inline-flex rounded-lg border border-red-300 px-4 py-2 text-sm font-medium text-red-700 hover:bg-red-50 dark:border-red-800 dark:text-red-300 dark:hover:bg-red-950/40" %>

            <div class="flex gap-3">
              <%= link_to "Abbrechen", users_path, class: "inline-flex rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-700" %>
              <%= f.submit "Speichern", class: "inline-flex rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
