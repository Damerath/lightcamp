                  <h3 class="text-sm font-semibold text-slate-900 dark:text-slate-100">Eingeteilte Mitarbeiter</h3>
                  <p class="mt-0.5 text-xs text-slate-500 dark:text-slate-400">Kompakter Teamüberblick für den DIY-Plan.</p>
                </div>
                <div class="flex flex-wrap gap-2">
                  <% if @assigned_applications.any? %>
                    <% @assigned_applications.each do |application| %>
                      <div class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-slate-50 px-3 py-1.5 text-xs font-medium text-slate-700 dark:border-slate-700 dark:bg-slate-900/40 dark:text-slate-200">
                        <span><%= [application.user.first_name, application.user.last_name].compact.join(" ").presence || application.user.email %></span>
                        <% if application.assigned_as_responsible? %>
                          <span class="rounded-full bg-amber-100 px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-amber-700 dark:bg-amber-900/60 dark:text-amber-200">V</span>
                        <% end %>
                      </div>
                    <% end %>
                  <% else %>
                    <p class="text-xs text-slate-500 dark:text-slate-400">Noch niemand eingeteilt.</p>
                  <% end %>
                </div>
              </div>
            </div>

            <div class="rounded-2xl bg-white p-6 shadow dark:bg-slate-800">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100">DIY-Plan</h3>
                  <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
                    Allgemeines Angebot und Spezial des Tages im Wochenblick pro Camptag.
                  </p>
                </div>
                <%= link_to "Druckansicht", admin_camp_team_diy_plan_print_path(@camp, @camp_team), target: "_blank", rel: "noreferrer", class: "inline-flex rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-700" %>
              </div>

              <% if @camp.day_range.blank? %>
                <div class="mt-5 rounded-2xl border border-dashed border-slate-300 px-4 py-6 text-sm text-slate-500 dark:border-slate-700 dark:text-slate-400">
                  Bitte pflegt zuerst beim Camp ein Von- und Bis-Datum.
                </div>
              <% else %>
                <div class="mt-5">
                  <div class="grid overflow-hidden rounded-2xl border border-slate-200 bg-slate-50/70 dark:border-slate-700 dark:bg-slate-900/30" style="grid-template-columns: repeat(<%= @camp_diy_day_plans.size %>, minmax(0, 1fr));">
                    <% @camp_diy_day_plans.each do |diy_day_plan| %>
                      <div class="<%= diy_day_plan == @camp_diy_day_plans.first ? '' : 'border-l border-slate-200 dark:border-slate-700' %> p-4">
                        <div class="border-b border-slate-200 pb-3 dark:border-slate-700">
                          <p class="text-sm font-semibold text-slate-900 dark:text-slate-100"><%= l(diy_day_plan.planned_on, format: "%A") %></p>
                          <p class="text-xs text-slate-500 dark:text-slate-400"><%= l(diy_day_plan.planned_on, format: "%d.%m.%Y") %></p>
                        </div>

                        <%= form_with model: diy_day_plan, url: admin_camp_diy_day_plan_path(@camp, @camp_team, diy_day_plan), method: :patch, class: "mt-4 space-y-3" do |f| %>
                          <div>
                            <div class="mb-1.5 flex items-center justify-between gap-2">
                              <%= f.label :general_offer, "Allgemeines Angebot", class: "block text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400" %>
                              <%= button_to "Für alle Tage", apply_general_offer_to_all_admin_camp_diy_day_plan_path(@camp, @camp_team, diy_day_plan), method: :post, params: { camp_diy_day_plan: { general_offer: diy_day_plan.general_offer } }, class: "inline-flex rounded-md border border-slate-300 px-2.5 py-1 text-[11px] font-medium text-slate-700 hover:bg-slate-100 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-700" %>
                            </div>
                            <%= f.text_area :general_offer, rows: 3, placeholder: "z. B. Offene Bastelstationen, Werken, Karten gestalten", class: "w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 outline-none transition focus:border-blue-400 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
                          </div>
                          <div>
                            <%= f.label :daily_special, "Spezial des Tages", class: "mb-1.5 block text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400" %>
                            <%= f.text_area :daily_special, rows: 3, placeholder: "z. B. Makramee, Holzschild, Fotowand", class: "w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 outline-none transition focus:border-blue-400 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
                          </div>
                          <div class="flex justify-end pt-0.5">
                            <%= f.submit "Speichern", class: "inline-flex rounded-lg bg-red-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-red-700" %>
                          </div>
                        <% end %>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      <% elsif @section == "room_plan" %>
        <div class="space-y-6">
          <div class="rounded-2xl bg-white p-6 shadow dark:bg-slate-800">
            <div class="flex items-start justify-between gap-4">
              <div>
                <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Zimmerplan</h3>
                <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
                  Verteile hier die Mitarbeitenden auf Zimmer und zusätzliche Schlafmöglichkeiten dieses Camps.
                </p>
              </div>
              <div class="flex items-center gap-3">
                <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700 dark:bg-slate-900/60 dark:text-slate-300">
                  <%= @camp_room_candidates.size %> Mitarbeitende
                </span>
                <%= link_to "Druckansicht", admin_camp_team_room_plan_print_path(@camp, @camp_team), target: "_blank", rel: "noreferrer", class: "inline-flex rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-700" %>
              </div>
            </div>

            <div class="mt-5 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
              <% @camp_sleeping_places.each do |place| %>
                <div class="rounded-2xl border border-slate-200 bg-slate-50/70 p-4 dark:border-slate-700 dark:bg-slate-900/30">
                  <div class="flex items-start justify-between gap-3">
                    <div>
                      <div class="flex items-center gap-2">
                        <h4 class="text-base font-semibold text-slate-900 dark:text-slate-100"><%= place.name %></h4>
                        <% if place.family_only? %>
                          <span class="rounded-full bg-amber-100 px-2 py-0.5 text-[11px] font-medium text-amber-700 dark:bg-amber-900/60 dark:text-amber-200">Familie</span>
                        <% elsif place.custom? %>
                          <span class="rounded-full bg-sky-100 px-2 py-0.5 text-[11px] font-medium text-sky-700 dark:bg-sky-900/60 dark:text-sky-200">Extra</span>
                        <% end %>
                      </div>
                      <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">
                        <%= place.capacity %> Plätze<%= place.details.present? && !place.family_only? ? " · #{place.details}" : "" %>
                      </p>
                    </div>
                    <span class="rounded-full <%= place.occupancy_count > place.capacity ? 'bg-red-100 text-red-700 dark:bg-red-900/60 dark:text-red-200' : 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/60 dark:text-emerald-200' %> px-2.5 py-1 text-xs font-medium">
                      <%= place.occupancy_count %>/<%= place.capacity %>
                    </span>
                  </div>

                  <div class="mt-4 space-y-2">
                    <% assigned_people = @camp_room_assignments_by_place_id[place.id] || [] %>
                    <% extra_people = @camp_room_people_by_place_id[place.id] || [] %>
                    <% if assigned_people.any? %>
                      <% assigned_people.each do |application| %>
                        <div class="rounded-lg border border-slate-200 bg-white px-3 py-2 dark:border-slate-700 dark:bg-slate-900">
                          <p class="text-sm font-medium text-slate-900 dark:text-slate-100"><%= [application.user.first_name, application.user.last_name].compact.join(" ") %></p>
                          <p class="text-xs text-slate-500 dark:text-slate-400"><%= application.assigned_camp_team&.name || "-" %></p>
                        </div>
                      <% end %>
                    <% end %>
                    <% extra_people.each do |person| %>
                      <div class="rounded-lg border border-sky-200 bg-sky-50/70 px-3 py-2 dark:border-sky-900/60 dark:bg-sky-950/20">
                        <p class="text-sm font-medium text-slate-900 dark:text-slate-100"><%= person.name %></p>
                        <p class="text-xs text-slate-500 dark:text-slate-400"><%= person.kind_label %><%= person.related_camp_application&.user.present? ? " · zu #{person.related_camp_application.user.first_name} #{person.related_camp_application.user.last_name}" : "" %></p>
                      </div>
                    <% end %>
                    <% if assigned_people.empty? && extra_people.empty? %>
                      <p class="text-sm text-slate-500 dark:text-slate-400">Noch niemand zugewiesen.</p>
                    <% end %>
                  </div>

                  <% if place.custom? %>
                    <div class="mt-4 flex justify-end">
                      <%= link_to "Entfernen", admin_camp_sleeping_place_path(@camp, @camp_team, place), data: { turbo_method: :delete, turbo_confirm: "Diese Schlafmöglichkeit wirklich entfernen?" }, class: "text-sm font-medium text-red-600 hover:text-red-700 dark:text-red-400" %>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>

          <div class="rounded-2xl bg-white p-6 shadow dark:bg-slate-800">
            <div>
              <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Weitere Schlafmöglichkeit hinzufügen</h3>
              <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
                Für Wohnwagen, Zelt oder andere Sonderfälle kannst du hier zusätzliche Plätze anlegen.
              </p>
            </div>

            <%= form_with model: CampSleepingPlace.new, url: admin_camp_sleeping_places_path(@camp, @camp_team), class: "mt-5 grid gap-4 md:grid-cols-[1.1fr_8rem_1fr_auto]" do |f| %>
              <div>
                <%= f.label :name, "Name", class: "mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300" %>
                <%= f.text_field :name, placeholder: "z. B. Wohnwagen Müller", class: "w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-slate-900 outline-none transition focus:border-blue-400 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
              </div>
              <div>
                <%= f.label :capacity, "Plätze", class: "mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300" %>
                <%= f.number_field :capacity, min: 1, value: 1, class: "w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-slate-900 outline-none transition focus:border-blue-400 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
              </div>
              <div>
                <%= f.label :details, "Hinweis", class: "mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300" %>
                <%= f.text_field :details, placeholder: "z. B. Zelt, Wohnwagen, Gästezimmer", class: "w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-slate-900 outline-none transition focus:border-blue-400 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
              </div>
              <div class="flex items-end">
                <%= f.submit "Hinzufügen", class: "inline-flex rounded-lg bg-red-600 px-4 py-2.5 text-sm font-medium text-white hover:bg-red-700" %>
              </div>
            <% end %>
          </div>

          <div class="rounded-2xl bg-white p-6 shadow dark:bg-slate-800">
            <div>
              <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Mitarbeitende zuweisen</h3>
              <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
