              <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Einkaufsliste</h3>
              <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
                Verwalte hier camp-spezifische Einkäufe und Besorgungen für das Team.
              </p>
            </div>
            <%= link_to "Druckansicht", admin_camp_team_shopping_print_path(@camp, @camp_team), target: "_blank", rel: "noreferrer", class: "inline-flex rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-700" %>
          </div>

          <div class="mt-5 space-y-3">
            <% if @camp_team_shopping_items.any? %>
              <% @camp_team_shopping_items.each do |item| %>
                <div class="flex items-start justify-between gap-4 rounded-lg border border-slate-200 px-4 py-3 dark:border-slate-700">
                  <div class="flex items-start gap-3">
                    <%= form_with model: item, url: admin_camp_team_shopping_item_path(@camp, @camp_team, item), method: :patch do |f| %>
                      <%= f.check_box :purchased, { checked: item.purchased, onchange: "this.form.requestSubmit()", class: "mt-1 h-4 w-4 rounded border-slate-300 text-blue-500 focus:ring-blue-400 dark:border-slate-600 dark:bg-slate-900" }, "1", "0" %>
                    <% end %>
                    <div>
                      <p class="<%= item.purchased? ? 'text-slate-400 line-through dark:text-slate-500' : 'text-slate-900 dark:text-slate-100' %> font-medium">
                        <%= item.name %>
                        <% if item.quantity.present? %>
                          <span class="ml-2 text-sm font-normal text-slate-500 dark:text-slate-400"><%= item.quantity %></span>
                        <% end %>
                      </p>
                      <% if item.notes.present? %>
                        <p class="mt-1 text-sm text-slate-500 dark:text-slate-400"><%= item.notes %></p>
                      <% end %>
                    </div>
                  </div>
                  <%= link_to "Entfernen", admin_camp_team_shopping_item_path(@camp, @camp_team, item), data: { turbo_method: :delete, turbo_confirm: "Eintrag wirklich entfernen?" }, class: "text-sm font-medium text-red-600 hover:text-red-700 dark:text-red-400" %>
                </div>
              <% end %>
            <% else %>
              <p class="text-sm text-slate-500 dark:text-slate-400">Noch keine Einträge in der Einkaufsliste.</p>
            <% end %>
          </div>

          <%= form_with model: CampTeamShoppingItem.new, url: admin_camp_team_shopping_items_path(@camp, @camp_team), class: "mt-5 grid gap-4 sm:grid-cols-[minmax(0,1.2fr)_10rem] lg:grid-cols-[minmax(0,1.2fr)_10rem_minmax(0,1fr)_auto]" do |f| %>
            <div>
              <%= f.label :name, "Artikel", class: "mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300" %>
              <%= f.text_field :name, placeholder: "z. B. Becher", class: "w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-slate-900 outline-none transition focus:border-blue-400 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
            </div>
            <div>
              <%= f.label :quantity, "Menge", class: "mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300" %>
              <%= f.text_field :quantity, placeholder: "z. B. 3 Packungen", class: "w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-slate-900 outline-none transition focus:border-blue-400 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
            </div>
            <div>
              <%= f.label :notes, "Notiz", class: "mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300" %>
              <%= f.text_field :notes, placeholder: "optional", class: "w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-slate-900 outline-none transition focus:border-blue-400 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
            </div>
            <div class="flex items-end">
              <%= f.submit "Hinzufügen", class: "inline-flex rounded-lg bg-red-600 px-4 py-2.5 text-sm font-medium text-white hover:bg-red-700" %>
            </div>
          <% end %>
        </div>
      <% elsif @section == "program" %>
        <div class="rounded-2xl bg-white p-6 shadow dark:bg-slate-800">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Tagesplan</h3>
              <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
                Der normale Camp-Tag für die Programmleiter. Unsichtbare Blöcke bleiben später für andere Bereiche verborgen.
              </p>
            </div>
            <div class="flex items-center gap-3">
              <%= link_to "Block hinzufügen", admin_camp_team_page_path(@camp, @camp_team, section: "program", modal: "new_program_block"), class: "inline-flex rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700" %>
              <%= button_to "Standard wiederherstellen", reset_admin_camp_program_blocks_path(@camp, @camp_team), method: :post, data: { turbo_confirm: "Den aktuellen Tagesplan wirklich durch den Standard ersetzen?" }, class: "inline-flex rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-700" %>
            </div>
          </div>

          <div class="mt-5 overflow-hidden rounded-2xl border border-slate-200 bg-white dark:border-slate-700 dark:bg-slate-900/30">
            <% @camp_program_blocks.each_with_index do |block, index| %>
              <div class="<%= index.positive? ? 'border-t border-slate-200 dark:border-slate-700' : '' %> px-4 py-2.5 sm:px-5">
                <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                  <div class="flex min-w-0 items-center gap-3">
                    <span class="h-3 w-3 shrink-0 rounded-full <%= block.color_accent_class %>"></span>
                    <div class="w-16 shrink-0 text-sm font-semibold text-slate-900 dark:text-slate-100">
                      <%= block.starts_at_label %>
                    </div>
                    <div class="min-w-0 flex-1">
                      <div class="flex flex-wrap items-center gap-2">
                        <span class="truncate font-medium text-slate-900 dark:text-slate-100"><%= block.title %></span>
                        <% unless block.visible_to_others? %>
                          <span class="rounded-full bg-amber-100 px-2 py-0.5 text-xs font-medium text-amber-700 dark:bg-amber-900 dark:text-amber-200">
                            versteckt
                          </span>
                        <% end %>
                      </div>
                    </div>
                  </div>
                  <div class="flex items-center justify-end gap-2">
                    <%= link_to admin_camp_team_page_path(@camp, @camp_team, section: "program", modal: "edit_program_block", program_block_id: block.id), class: "inline-flex rounded-lg border border-slate-300 px-2.5 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-100 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-700" do %>
                      <i data-lucide="pencil" class="h-4 w-4"></i>
                    <% end %>
                    <%= link_to admin_camp_program_block_path(@camp, @camp_team, block), data: { turbo_method: :delete, turbo_confirm: "Block wirklich löschen?" }, class: "inline-flex rounded-lg border border-slate-300 px-2.5 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-100 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-700" do %>
                      <i data-lucide="trash-2" class="h-4 w-4"></i>
                    <% end %>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% elsif @section == "week_plan" %>
        <div class="rounded-2xl bg-white p-6 shadow dark:bg-slate-800">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Wochenplan</h3>
              <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
                <%= @week_plan_read_only ? "Die veröffentlichte Leseansicht für dieses Camp." : "Der Wochenplan zeigt eure Camp-Tage im Überblick. Die Blockhöhe orientiert sich jeweils am nächsten Startpunkt." %>
              </p>
            </div>
            <div class="flex items-center gap-3">
              <%= link_to "Druckansicht", admin_camp_team_week_plan_print_path(@camp, @camp_team), target: "_blank", rel: "noreferrer", class: "inline-flex rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-700" %>
              <% if @camp_team.program_team? %>
                <%= form_with model: @camp_team, url: admin_camp_team_path(@camp, @camp_team), method: :patch do |f| %>
                  <%= hidden_field_tag :from, "team_page" %>
                  <%= hidden_field_tag :section, "week_plan" %>
                  <%= hidden_field_tag :return_to, admin_camp_team_page_path(@camp, @camp_team, section: "week_plan") %>
                  <%= f.hidden_field :week_plan_published, value: @camp_team.week_plan_published? ? "0" : "1" %>
                  <%= f.submit(@camp_team.week_plan_published? ? "Veröffentlichung aufheben" : "Wochenplan veröffentlichen", class: "inline-flex rounded-lg #{ @camp_team.week_plan_published? ? 'border border-amber-300 text-amber-700 hover:bg-amber-50 dark:border-amber-900 dark:text-amber-300 dark:hover:bg-amber-950/40' : 'bg-red-600 text-white hover:bg-red-700' } px-4 py-2 text-sm font-medium") %>
                <% end %>
              <% end %>
            </div>
          </div>

          <% if @camp_team.program_team? && @camp_team.week_plan_published? %>
            <div class="mt-4 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800 dark:border-emerald-900/60 dark:bg-emerald-950/30 dark:text-emerald-200">
              Dieser Wochenplan ist aktuell für alle anderen Teams dieses Camps sichtbar.
            </div>
          <% elsif @week_plan_read_only %>
            <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700 dark:border-slate-700 dark:bg-slate-900/40 dark:text-slate-300">
              Dies ist eine veröffentlichte Leseansicht. Änderungen nehmt ihr weiterhin im Bereich der Programmleiter vor.
            </div>
          <% end %>

          <% if @camp_program_week_dates.blank? %>
            <div class="mt-5 rounded-2xl border border-dashed border-slate-300 px-4 py-6 text-sm text-slate-500 dark:border-slate-700 dark:text-slate-400">
              Bitte pflege zuerst beim Camp ein Von- und Bis-Datum. Danach koennen wir hier die echten Camp-Tage anzeigen.
            </div>
          <% else %>
            <% timeline_start_hour = 7 %>
            <% timeline_end_hour = 24 %>
            <% hour_height = 72 %>
            <% timeline_height = (timeline_end_hour - timeline_start_hour) * hour_height %>
            <% time_column_width = 4.75 %>
            <% day_column_width = @camp_program_week_dates.size >= 8 ? 10.0 : 11.0 %>

            <div class="relative left-1/2 mt-6 w-screen max-w-none -translate-x-1/2 px-4 sm:px-6 xl:px-8">
              <div class="overflow-x-auto pb-2">
                <div class="min-w-[980px]">
                  <div class="grid gap-px overflow-hidden rounded-2xl border border-slate-200 bg-slate-200 dark:border-slate-700 dark:bg-slate-700" style="grid-template-columns: <%= time_column_width %>rem repeat(<%= @camp_program_week_dates.size %>, minmax(<%= day_column_width %>rem, 1fr));">
                  <div class="bg-slate-50 px-4 py-3 text-sm font-semibold text-slate-700 dark:bg-slate-800 dark:text-slate-300">
                    Zeit
                  </div>

                  <% @camp_program_week_dates.each do |planned_on| %>
                    <% week_day = @camp_program_week_days_by_date[planned_on] %>
                    <div class="bg-slate-50 px-4 py-3 dark:bg-slate-800">
                      <div class="flex items-start justify-between gap-3">
                        <div>
                          <p class="text-sm font-semibold text-slate-900 dark:text-slate-100"><%= l(planned_on, format: "%d.%m.") %></p>
                          <p class="text-xs text-slate-500 dark:text-slate-400"><%= l(planned_on, format: "%A") %></p>
                        </div>

                        <% if week_day&.label.present? %>
                          <span class="rounded-full border border-sky-200 bg-sky-100 px-2.5 py-1 text-[11px] font-medium text-sky-800 dark:border-sky-900/70 dark:bg-sky-950/40 dark:text-sky-200">
                            <%= week_day.label %>
                          </span>
                        <% end %>
                      </div>

                      <div class="mt-3 flex flex-wrap gap-2">
                        <% if week_day.present? && !@week_plan_read_only %>
                          <%= form_with model: week_day, url: admin_camp_program_week_day_path(@camp, @camp_team, week_day), method: :patch do |f| %>
                            <%= f.hidden_field :mode, value: "default_plan" %>
                            <%= f.submit "Tagesplan einfügen", class: "inline-flex rounded-lg bg-slate-900 px-3 py-1.5 text-xs font-medium text-white dark:bg-slate-100 dark:text-slate-900" %>
                          <% end %>
                          <%= link_to "Block +", admin_camp_team_page_path(@camp, @camp_team, section: "week_plan", modal: "new_week_block", week_day_id: week_day.id), class: "inline-flex rounded-lg border border-slate-300 px-3 py-1.5 text-xs font-medium text-slate-700 hover:bg-slate-100 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-700" %>
                          <%= link_to "Hinweis", admin_camp_team_page_path(@camp, @camp_team, section: "week_plan", modal: "edit_week_day", week_day_id: week_day.id), class: "inline-flex rounded-lg border border-slate-300 px-3 py-1.5 text-xs font-medium text-slate-700 hover:bg-slate-100 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-700" %>
                          <%= link_to "Tag löschen", admin_camp_program_week_day_path(@camp, @camp_team, week_day), data: { turbo_method: :delete, turbo_confirm: "Diesen Camp-Tag wirklich aus dem Wochenplan entfernen?" }, class: "inline-flex rounded-lg border border-red-300 px-3 py-1.5 text-xs font-medium text-red-700 hover:bg-red-50 dark:border-red-900 dark:text-red-300 dark:hover:bg-red-950/40" %>
                        <% elsif !@week_plan_read_only %>
                          <%= form_with url: admin_camp_program_week_days_path(@camp, @camp_team), method: :post do |f| %>
                            <%= f.hidden_field :planned_on, value: planned_on.iso8601, name: "camp_program_week_day[planned_on]" %>
                            <%= f.hidden_field :mode, value: "default_plan", name: "camp_program_week_day[mode]" %>
                            <%= f.submit "Tagesplan einfügen", class: "inline-flex rounded-lg bg-slate-900 px-3 py-1.5 text-xs font-medium text-white dark:bg-slate-100 dark:text-slate-900" %>
                          <% end %>
                          <%= form_with url: admin_camp_program_week_days_path(@camp, @camp_team), method: :post do |f| %>
                            <%= f.hidden_field :planned_on, value: planned_on.iso8601, name: "camp_program_week_day[planned_on]" %>
                            <%= f.hidden_field :mode, value: "custom", name: "camp_program_week_day[mode]" %>
                            <%= hidden_field_tag :open_modal, "new_week_block" %>
                            <%= f.submit "Block +", class: "inline-flex rounded-lg border border-slate-300 px-3 py-1.5 text-xs font-medium text-slate-700 hover:bg-slate-100 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-700" %>
                          <% end %>
                          <%= form_with url: admin_camp_program_week_days_path(@camp, @camp_team), method: :post do |f| %>
                            <%= f.hidden_field :planned_on, value: planned_on.iso8601, name: "camp_program_week_day[planned_on]" %>
                            <%= f.hidden_field :mode, value: "custom", name: "camp_program_week_day[mode]" %>
                            <%= hidden_field_tag :open_modal, "edit_week_day" %>
                            <%= f.submit "Hinweis", class: "inline-flex rounded-lg border border-slate-300 px-3 py-1.5 text-xs font-medium text-slate-700 hover:bg-slate-100 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-700" %>
                          <% end %>
                        <% end %>
                      </div>
                    </div>
                  <% end %>

                  <div class="relative bg-white dark:bg-slate-900/30" style="height: <%= timeline_height %>px;">
                    <% (timeline_start_hour..timeline_end_hour).each do |hour| %>
                      <% top = (hour - timeline_start_hour) * hour_height %>
                      <% break if hour == timeline_end_hour %>
                      <div class="absolute inset-x-0 border-t border-slate-200 dark:border-slate-700" style="top: <%= top %>px;"></div>
                      <div class="absolute left-0 -translate-y-1/2 px-3 text-sm font-medium text-slate-500 dark:text-slate-400" style="top: <%= top %>px;">
                        <%= format("%02d:00", hour) %>
                      </div>
                    <% end %>
                  </div>

                  <% @camp_program_week_dates.each do |planned_on| %>
                    <% week_day = @camp_program_week_days_by_date[planned_on] %>
                    <% blocks = week_day.present? ? week_day.camp_program_week_blocks.ordered.to_a : [] %>

                    <div class="relative bg-white dark:bg-slate-900/30" style="height: <%= timeline_height %>px;">
                      <% (timeline_start_hour..timeline_end_hour).each do |hour| %>
                        <% top = (hour - timeline_start_hour) * hour_height %>
                        <% break if hour == timeline_end_hour %>
                        <div class="absolute inset-x-0 border-t border-slate-100 dark:border-slate-800" style="top: <%= top %>px;"></div>
                      <% end %>

                      <% if blocks.empty? %>
                        <div class="absolute inset-x-3 rounded-xl border border-dashed border-slate-300 bg-slate-50/70 px-3 py-3 text-xs text-slate-500 dark:border-slate-700 dark:bg-slate-900/40 dark:text-slate-400" style="top: 0.75rem;">
                          Noch nichts geplant
                        </div>
                      <% else %>
                        <% blocks.each_with_index do |block, index| %>
                          <% next_start = blocks[index + 1]&.starts_at_minutes || (timeline_end_hour * 60) %>
                          <% block_start = [[block.starts_at_minutes, timeline_start_hour * 60].max, timeline_end_hour * 60].min %>
                          <% block_end = [[next_start, block_start + 5].max, timeline_end_hour * 60].min %>
                          <% top = ((block_start - (timeline_start_hour * 60)) / 60.0) * hour_height %>
                          <% raw_height = ((block_end - block_start) / 60.0) * hour_height %>
                          <% compact_block = raw_height < 54 %>
                          <% height = compact_block ? [raw_height - 2, 14].max : [raw_height - 6, 22].max %>
                          <% ultra_compact_block = height < 18 %>
                          <% block_classes = block.color_card_classes %>

                          <div class="absolute inset-x-2 overflow-hidden rounded-xl border shadow-sm <%= block_classes %> <%= compact_block ? 'px-2.5 py-1.5 pr-9' : 'px-3 py-2' %>" style="top: <%= top + 3 %>px; height: <%= height %>px;">
                            <% if compact_block %>
                              <% if ultra_compact_block %>
                                <% unless @week_plan_read_only %>
                                  <%= link_to admin_camp_team_page_path(@camp, @camp_team, section: "week_plan", modal: "edit_week_block", week_block_id: block.id), class: "absolute right-1 top-1/2 -translate-y-1/2 inline-flex h-4 w-4 items-center justify-center rounded border border-current/20 bg-white/70 hover:bg-white dark:bg-slate-900/50 dark:hover:bg-slate-900" do %>
                                    <i data-lucide="pencil" class="h-2.5 w-2.5"></i>
                                  <% end %>
                                <% end %>
                                <div class="flex h-full items-center gap-1.5 pr-4">
                                  <p class="shrink-0 text-[10px] font-semibold leading-none opacity-80"><%= block.starts_at_label %></p>
                                  <p class="truncate text-[11px] font-semibold leading-none"><%= block.title %></p>
                                </div>
                              <% else %>
                                <% unless @week_plan_read_only %>
                                  <%= link_to admin_camp_team_page_path(@camp, @camp_team, section: "week_plan", modal: "edit_week_block", week_block_id: block.id), class: "absolute right-1.5 top-1.5 inline-flex rounded-md border border-current/20 bg-white/70 px-1.5 py-1 text-xs font-medium hover:bg-white dark:bg-slate-900/50 dark:hover:bg-slate-900" do %>
                                    <i data-lucide="pencil" class="h-3 w-3"></i>
                                  <% end %>
                                <% end %>
                                <div class="flex items-center gap-2">
                                  <p class="shrink-0 text-xs font-semibold opacity-80"><%= block.starts_at_label %></p>
                                  <p class="truncate text-[13px] font-semibold leading-tight"><%= block.title %></p>
                                </div>
                              <% end %>
                            <% else %>
                              <div class="flex items-start justify-between gap-2">
                                <div class="min-w-0">
                                  <p class="text-xs font-semibold opacity-80"><%= block.starts_at_label %></p>
                                  <div class="mt-1 flex items-start justify-between gap-2">
                                    <p class="min-w-0 text-sm font-semibold leading-snug"><%= block.title %></p>
                                    <% unless block.visible_to_others? %>
                                      <div class="shrink-0 rounded-full bg-black/10 px-2 py-0.5 text-[11px] font-medium dark:bg-white/10">
                                        versteckt
                                      </div>
                                    <% end %>
                                  </div>
                                </div>

                                <% unless @week_plan_read_only %>
                                  <div class="flex items-center gap-1">
                                    <%= link_to admin_camp_team_page_path(@camp, @camp_team, section: "week_plan", modal: "edit_week_block", week_block_id: block.id), class: "inline-flex rounded-md border border-current/20 bg-white/70 px-2 py-1 text-xs font-medium hover:bg-white dark:bg-slate-900/50 dark:hover:bg-slate-900" do %>
                                      <i data-lucide="pencil" class="h-3.5 w-3.5"></i>
                                    <% end %>
                                  </div>
                                <% end %>
                              </div>
                            <% end %>
                          </div>
                        <% end %>
                      <% end %>
                    </div>
                  <% end %>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    <% unless %w[program week_plan sport_plan material_list medical_supplies kitchen_plan diy_plan room_plan].include?(@section) %>
      </div>

      <aside class="rounded-2xl bg-white p-6 shadow dark:bg-slate-800">
      <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Eingeteilte Mitarbeiter</h3>
      <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
        <%= @camp_team.year_shared_team? ? "Die aktuelle Besetzung dieses Bereichs ueber alle Freizeiten des Jahres." : "Die aktuelle Teamzusammensetzung dieses Camp-Teams." %>
      </p>

      <div class="mt-5 space-y-3">
        <% if @assigned_applications.any? %>
          <% @assigned_applications.each do |application| %>
            <div class="rounded-lg border border-slate-200 px-4 py-3 dark:border-slate-700">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <p class="font-medium text-slate-900 dark:text-slate-100">
                    <%= application.user.first_name %> <%= application.user.last_name %>
                  </p>
                  <div class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400">
                    <span><%= application.user.gender == "male" ? "m" : application.user.gender == "female" ? "w" : "-" %></span>
                    <% if @camp_team.media_team? && application.assigned_camp_team.present? %>
                      <span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-600 dark:bg-slate-900/60 dark:text-slate-300">
                        <%= application.assigned_camp_team.name %>
                      </span>
                    <% elsif @camp_team.year_shared_team? && application.assigned_camp.present? %>
                      <span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-600 dark:bg-slate-900/60 dark:text-slate-300">
                        <%= application.assigned_camp.name %>
                      </span>
                    <% end %>
                  </div>
                </div>

                <% if application.assigned_as_responsible? %>
                  <span class="rounded-full bg-amber-100 px-2 py-1 text-xs font-medium text-amber-700 dark:bg-amber-900 dark:text-amber-200">
                    verantwortlich
                  </span>
                <% end %>
              </div>
            </div>
          <% end %>
        <% else %>
          <p class="text-sm text-slate-500 dark:text-slate-400">Noch niemand eingeteilt.</p>
        <% end %>
      </div>
      </aside>
    </div>
    <% end %>

  <% if @program_block_modal.present? %>
    <% editing = @program_block_modal.persisted? %>
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-slate-950/60 px-4">
      <div class="w-full max-w-lg rounded-2xl bg-white p-6 shadow-2xl dark:bg-slate-800">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100"><%= editing ? "Block bearbeiten" : "Block hinzufügen" %></h3>
            <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">Zeit, Titel und Sichtbarkeit dieses Tagesplan-Blocks.</p>
          </div>
          <%= link_to admin_camp_team_page_path(@camp, @camp_team, section: "program"), class: "inline-flex rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-700" do %>
            <i data-lucide="x" class="h-4 w-4"></i>
          <% end %>
        </div>

        <%= form_with model: @program_block_modal, url: editing ? admin_camp_program_block_path(@camp, @camp_team, @program_block_modal) : admin_camp_program_blocks_path(@camp, @camp_team), method: editing ? :patch : :post, class: "mt-5 space-y-4" do |f| %>
          <div class="grid gap-4 md:grid-cols-[10.5rem_minmax(0,1fr)]">
            <div class="min-w-0">
              <label class="mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300">Uhrzeit</label>
              <div class="grid grid-cols-[4.75rem_auto_4.75rem] items-center gap-2">
                <%= f.select :starts_at_hour, options_for_select((0..23).map { |hour| [format("%02d", hour), format("%02d", hour)] }, @program_block_modal.try(:start_hour)), {}, class: "block w-[4.75rem] rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 outline-none transition focus:border-blue-400 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
                <span class="text-sm font-medium text-slate-500 dark:text-slate-400">:</span>
                <%= f.select :starts_at_minute, options_for_select((0..55).step(5).map { |minute| [format("%02d", minute), format("%02d", minute)] }, @program_block_modal.try(:start_minute)), {}, class: "block w-[4.75rem] rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 outline-none transition focus:border-blue-400 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
              </div>
            </div>

            <div class="min-w-0">
              <%= f.label :title, "Titel", class: "mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300" %>
              <%= f.text_field :title, class: "w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-slate-900 outline-none transition focus:border-blue-400 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
            </div>
          </div>

          <label class="flex items-center gap-3 rounded-lg border border-slate-200 px-4 py-3 text-sm text-slate-700 dark:border-slate-700 dark:text-slate-300">
            <%= f.check_box :visible_to_others, { checked: @program_block_modal.visible_to_others != false }, "1", "0" %>
            Für andere sichtbar
          </label>
          <div>
            <%= f.label :color, "Farbe", class: "mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300" %>
            <%= f.select :color,
              options_for_select(CampProgramBlock::COLOR_THEMES.map { |key, config| [config[:label], key] }, @program_block_modal.color.presence || "blue"),
              {},
              class: "w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-slate-900 outline-none transition focus:border-blue-400 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
          </div>

          <div class="flex items-center justify-end gap-3">
            <%= link_to "Abbrechen", admin_camp_team_page_path(@camp, @camp_team, section: "program"), class: "inline-flex rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-700" %>
            <%= f.submit(editing ? "Speichern" : "Block hinzufügen", class: "inline-flex rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700") %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @program_week_block_modal.present? %>
    <% editing = @program_week_block_modal.persisted? %>
    <% week_day = editing ? @program_week_block_modal.camp_program_week_day : @camp_team.camp_program_week_days.find_by(id: params[:week_day_id]) %>
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-slate-950/60 px-4">
      <div class="w-full max-w-lg rounded-2xl bg-white p-6 shadow-2xl dark:bg-slate-800">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100"><%= editing ? "Wochenplan-Block bearbeiten" : "Wochenplan-Block hinzufügen" %></h3>
            <p class="mt-1 text-sm text-slate-600 dark:text-slate-400"><%= week_day&.label %> · eigener Tagesblock</p>
          </div>
          <%= link_to admin_camp_team_page_path(@camp, @camp_team, section: "week_plan"), class: "inline-flex rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-700" do %>
            <i data-lucide="x" class="h-4 w-4"></i>
          <% end %>
        </div>

        <%= form_with model: @program_week_block_modal, url: editing ? admin_camp_program_week_block_path(@camp, @camp_team, @program_week_block_modal.camp_program_week_day, @program_week_block_modal) : admin_camp_program_week_blocks_path(@camp, @camp_team, week_day), method: editing ? :patch : :post, class: "mt-5 space-y-4" do |f| %>
          <div class="grid gap-4 md:grid-cols-[10.5rem_minmax(0,1fr)]">
            <div class="min-w-0">
              <label class="mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300">Uhrzeit</label>
              <div class="grid grid-cols-[4.75rem_auto_4.75rem] items-center gap-2">
                <%= f.select :starts_at_hour, options_for_select((0..23).map { |hour| [format("%02d", hour), format("%02d", hour)] }, @program_week_block_modal.try(:start_hour)), {}, class: "block w-[4.75rem] rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 outline-none transition focus:border-blue-400 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
                <span class="text-sm font-medium text-slate-500 dark:text-slate-400">:</span>
                <%= f.select :starts_at_minute, options_for_select((0..55).step(5).map { |minute| [format("%02d", minute), format("%02d", minute)] }, @program_week_block_modal.try(:start_minute)), {}, class: "block w-[4.75rem] rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 outline-none transition focus:border-blue-400 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
              </div>
            </div>
            <div class="min-w-0">
              <%= f.label :title, "Titel", class: "mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300" %>
              <%= f.text_field :title, class: "w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-slate-900 outline-none transition focus:border-blue-400 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
            </div>
          </div>
          <label class="flex items-center gap-3 rounded-lg border border-slate-200 px-4 py-3 text-sm text-slate-700 dark:border-slate-700 dark:text-slate-300">
            <%= f.check_box :visible_to_others, { checked: @program_week_block_modal.visible_to_others != false }, "1", "0" %>
            Für andere sichtbar
          </label>
          <div>
            <%= f.label :color, "Farbe", class: "mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300" %>
            <%= f.select :color,
              options_for_select(CampProgramBlock::COLOR_THEMES.map { |key, config| [config[:label], key] }, @program_week_block_modal.color.presence || "blue"),
              {},
              class: "w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-slate-900 outline-none transition focus:border-blue-400 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
          </div>
          <div class="flex items-center justify-between gap-3">
            <div>
              <% if editing %>
                <%= link_to "Löschen", admin_camp_program_week_block_path(@camp, @camp_team, @program_week_block_modal.camp_program_week_day, @program_week_block_modal), data: { turbo_method: :delete, turbo_confirm: "Diesen Block wirklich löschen?" }, class: "inline-flex rounded-lg border border-red-300 px-4 py-2 text-sm font-medium text-red-700 hover:bg-red-50 dark:border-red-900 dark:text-red-300 dark:hover:bg-red-950/40" %>
              <% end %>
            </div>
            <div class="flex items-center gap-3">
            <%= link_to "Abbrechen", admin_camp_team_page_path(@camp, @camp_team, section: "week_plan"), class: "inline-flex rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-700" %>
            <%= f.submit(editing ? "Speichern" : "Block hinzufügen", class: "inline-flex rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700") %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @program_week_day_modal.present? %>
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-slate-950/60 px-4">
      <div class="w-full max-w-md rounded-2xl bg-white p-6 shadow-2xl dark:bg-slate-800">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Tageshinweis</h3>
            <p class="mt-1 text-sm text-slate-600 dark:text-slate-400"><%= @program_week_day_modal.day_label %></p>
          </div>
          <%= link_to admin_camp_team_page_path(@camp, @camp_team, section: "week_plan"), class: "inline-flex rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-700" do %>
            <i data-lucide="x" class="h-4 w-4"></i>
          <% end %>
        </div>

        <%= form_with model: @program_week_day_modal, url: admin_camp_program_week_day_path(@camp, @camp_team, @program_week_day_modal), method: :patch, class: "mt-5 space-y-4" do |f| %>
          <div>
            <%= f.label :label, "Hinweis", class: "mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300" %>
            <%= f.text_field :label, placeholder: "z. B. Anreisetag oder Exkursion", class: "w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-slate-900 outline-none transition focus:border-blue-400 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
          </div>
          <div class="flex items-center justify-end gap-3">
            <%= link_to "Abbrechen", admin_camp_team_page_path(@camp, @camp_team, section: "week_plan"), class: "inline-flex rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-700" %>
            <%= f.submit "Speichern", class: "inline-flex rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700" %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
