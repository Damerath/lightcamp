<div class="space-y-8">
  <div class="flex items-start justify-between gap-4">
    <div>
      <p class="text-sm font-medium uppercase tracking-wide text-slate-500 dark:text-slate-400">
        <%= @camp_team.year_shared_team? ? "#{@camp.year.name} · Jahresbereich" : "#{@camp.year.name} · #{@camp.name}" %>
      </p>
      <h2 class="text-2xl font-bold"><%= @camp_team.workspace_label %></h2>
      <p class="mt-1 text-slate-600 dark:text-slate-400">
        <%= if @camp_team.media_team?
              "Gemeinsamer Medienbereich fuer Foto und Video."
            elsif @camp_team.year_shared_team?
              "Gemeinsamer Bereich ueber alle Freizeiten dieses Jahres."
            else
              "Teamseite mit gemeinsamen Infos, Links und ToDos."
            end %>
      </p>
    </div>

    <div class="flex items-center gap-3">
      <%= link_to "Zur Teamview", admin_camp_teams_path(@camp), class: "inline-flex rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-200 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-700" %>
      <%= link_to "Zur Campverwaltung", admin_camps_path, class: "inline-flex rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-200 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-700" %>
    </div>
  </div>

  <div class="inline-flex rounded-lg border border-slate-300 bg-white p-1 shadow-sm dark:border-slate-600 dark:bg-slate-800">
    <% [
      ["overview", "Übersicht"],
      ["description", "Aufgabenbeschreibung"],
      ["todos", "ToDos"],
      ["shopping", "Einkaufsliste"],
      ["downloads", "Downloads"]
    ].each do |key, label| %>
      <% active = @section == key %>
      <%= link_to label, admin_camp_team_page_path(@camp, @camp_team, section: key), class: "rounded-md px-3 py-1.5 text-sm font-medium transition #{active ? 'bg-blue-500 text-white shadow-sm' : 'text-slate-700 hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-700'}" %>
    <% end %>
    <% if @camp_team.sport_team? %>
      <% active = @section == "sport_plan" %>
      <%= link_to "Sportplan", admin_camp_team_page_path(@camp, @camp_team, section: "sport_plan"), class: "rounded-md px-3 py-1.5 text-sm font-medium transition #{active ? 'bg-blue-500 text-white shadow-sm' : 'text-slate-700 hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-700'}" %>
      <% active = @section == "material_list" %>
      <%= link_to "Materialliste", admin_camp_team_page_path(@camp, @camp_team, section: "material_list"), class: "rounded-md px-3 py-1.5 text-sm font-medium transition #{active ? 'bg-blue-500 text-white shadow-sm' : 'text-slate-700 hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-700'}" %>
    <% end %>
    <% if @camp_team.medical_team? %>
      <% active = @section == "medical_supplies" %>
      <%= link_to "Medizinische Versorgung", admin_camp_team_page_path(@camp, @camp_team, section: "medical_supplies"), class: "rounded-md px-3 py-1.5 text-sm font-medium transition #{active ? 'bg-blue-500 text-white shadow-sm' : 'text-slate-700 hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-700'}" %>
    <% end %>
    <% if @camp_team.kitchen_team? %>
      <% active = @section == "kitchen_plan" %>
      <%= link_to "Küchenplan", admin_camp_team_page_path(@camp, @camp_team, section: "kitchen_plan"), class: "rounded-md px-3 py-1.5 text-sm font-medium transition #{active ? 'bg-blue-500 text-white shadow-sm' : 'text-slate-700 hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-700'}" %>
    <% end %>
    <% if @camp_team.diy_team? %>
      <% active = @section == "diy_plan" %>
      <%= link_to "DIY-Plan", admin_camp_team_page_path(@camp, @camp_team, section: "diy_plan"), class: "rounded-md px-3 py-1.5 text-sm font-medium transition #{active ? 'bg-blue-500 text-white shadow-sm' : 'text-slate-700 hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-700'}" %>
    <% end %>
    <% if @camp_team.camp_leader_team? %>
      <% active = @section == "room_plan" %>
      <%= link_to "Zimmerplan", admin_camp_team_page_path(@camp, @camp_team, section: "room_plan"), class: "rounded-md px-3 py-1.5 text-sm font-medium transition #{active ? 'bg-blue-500 text-white shadow-sm' : 'text-slate-700 hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-700'}" %>
    <% end %>
    <% if @camp_team.program_team? %>
      <% active = @section == "program" %>
      <%= link_to "Tagesplan", admin_camp_team_page_path(@camp, @camp_team, section: "program"), class: "rounded-md px-3 py-1.5 text-sm font-medium transition #{active ? 'bg-blue-500 text-white shadow-sm' : 'text-slate-700 hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-700'}" %>
    <% end %>
    <% if @week_plan_available %>
      <% active = @section == "week_plan" %>
      <%= link_to "Wochenplan", admin_camp_team_page_path(@camp, @camp_team, section: "week_plan"), class: "rounded-md px-3 py-1.5 text-sm font-medium transition #{active ? 'bg-blue-500 text-white shadow-sm' : 'text-slate-700 hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-700'}" %>
    <% end %>
  </div>

  <% if %w[program week_plan sport_plan material_list medical_supplies kitchen_plan diy_plan room_plan].include?(@section) %>
    <div class="space-y-6">
  <% else %>
    <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_20rem]">
      <div class="space-y-6">
  <% end %>
      <% if @section == "overview" %>
        <% if @camp_team.shows_internal_meeting? %>
          <div class="rounded-2xl bg-white p-6 shadow dark:bg-slate-800">
            <div class="flex items-start justify-between gap-4">
              <div>
                <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Interner nächster Termin</h3>
                <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
                  Halte hier den nächsten internen Teamtermin fest.
                </p>
              </div>
              <% if @camp_team.next_internal_meeting_at.present? %>
                <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700 dark:bg-slate-900/60 dark:text-slate-300">
                  <%= l(@camp_team.next_internal_meeting_at, format: :long) %>
                </span>
              <% end %>
            </div>

            <%= form_with model: @camp_team, url: admin_camp_team_path(@camp, @camp_team), method: :patch, class: "mt-5 space-y-4" do |f| %>
              <%= hidden_field_tag :from, "team_page" %>
              <%= hidden_field_tag :section, "overview" %>
              <%= hidden_field_tag :return_to, admin_camp_team_page_path(@camp, @camp_team, section: "overview") %>
              <div class="grid gap-4 sm:grid-cols-[minmax(0,1fr)_11rem]">
                <div>
                  <label class="mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300">Datum</label>
                  <div class="relative" data-controller="datepicker" data-datepicker-default-to-today-value="true">
                    <%= f.hidden_field :next_internal_meeting_on, value: @camp_team.next_internal_meeting_at&.to_date&.strftime("%Y-%m-%d"), data: { datepicker_target: "value" } %>
                    <input
                      type="text"
                      value="<%= @camp_team.next_internal_meeting_at&.strftime('%d.%m.%Y') %>"
                      class="w-full cursor-pointer rounded-lg border border-slate-300 bg-white px-4 py-2.5 pr-11 text-slate-900 outline-none transition focus:border-blue-400 focus:ring-0 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100"
                      autocomplete="off"
                      placeholder="TT.MM.JJJJ"
                      data-datepicker-target="input"
                      data-action="click->datepicker#open focus->datepicker#open"
                    >
                    <button type="button" class="absolute inset-y-0 right-0 flex items-center pr-4 text-slate-400 dark:text-slate-500" data-action="click->datepicker#open">
                      <i data-lucide="calendar-days" class="h-4 w-4"></i>
                    </button>
                  </div>
                </div>

                <div>
                  <%= f.label :next_internal_meeting_time, "Uhrzeit", class: "mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300" %>
                  <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-2">
                    <%= f.select :next_internal_meeting_hour,
                      options_for_select((0..23).map { |hour| [format("%02d", hour), format("%02d", hour)] }, @camp_team.next_internal_meeting_at&.strftime("%H")),
                      { prompt: "Std" },
                      class: "block w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 outline-none transition focus:border-blue-400 focus:ring-0 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
                    <span class="text-sm font-medium text-slate-500 dark:text-slate-400">:</span>
                    <%= f.select :next_internal_meeting_minute,
                      options_for_select((0..55).step(5).map { |minute| [format("%02d", minute), format("%02d", minute)] }, @camp_team.next_internal_meeting_at&.strftime("%M")),
                      { prompt: "Min" },
                      class: "block w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 outline-none transition focus:border-blue-400 focus:ring-0 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
                  </div>
                </div>
              </div>
              <div class="flex justify-end">
                <%= f.submit "Termin speichern", class: "inline-flex rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700" %>
              </div>
            <% end %>
          </div>
        <% end %>

        <div class="rounded-2xl bg-white p-6 shadow dark:bg-slate-800">
          <div>
            <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Wichtige Links</h3>
            <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
              Zentrale Default-Links kommen aus der Teamverwaltung. Alles, was du hier hinzufügst, gilt nur für dieses Camp.
            </p>
          </div>

          <div class="mt-5 space-y-3">
            <% if @team_template_links.any? %>
              <% @team_template_links.each do |link| %>
                <div class="flex items-center justify-between gap-4 rounded-lg border border-sky-200 bg-sky-50/70 px-4 py-3 dark:border-sky-900/60 dark:bg-sky-950/20">
                  <div>
                    <div class="flex items-center gap-2">
                      <p class="font-medium text-slate-900 dark:text-slate-100"><%= link.title %></p>
                      <span class="rounded-full bg-sky-100 px-2 py-0.5 text-[11px] font-medium text-sky-700 dark:bg-sky-900/60 dark:text-sky-200">Default</span>
                    </div>
                    <%= link_to link.url, link.url, target: "_blank", rel: "noreferrer", class: "text-sm text-blue-600 hover:underline dark:text-blue-400" %>
                  </div>
                  <%= link_to "Verwalten", admin_team_template_path(@camp_team.team_template), class: "text-sm font-medium text-sky-700 hover:text-sky-800 dark:text-sky-300" %>
                </div>
              <% end %>
            <% end %>

            <% if @camp_team_links.any? %>
              <% @camp_team_links.each do |link| %>
                <div class="flex items-center justify-between gap-4 rounded-lg border border-slate-200 px-4 py-3 dark:border-slate-700">
                  <div>
                    <div class="flex items-center gap-2">
                      <p class="font-medium text-slate-900 dark:text-slate-100"><%= link.title %></p>
                      <span class="rounded-full bg-slate-100 px-2 py-0.5 text-[11px] font-medium text-slate-600 dark:bg-slate-900/60 dark:text-slate-300">Camp</span>
                    </div>
                    <%= link_to link.url, link.url, target: "_blank", rel: "noreferrer", class: "text-sm text-blue-600 hover:underline dark:text-blue-400" %>
                  </div>
                  <%= link_to "Entfernen", admin_camp_team_link_path(@camp, @camp_team, link), data: { turbo_method: :delete, turbo_confirm: "Link wirklich entfernen?" }, class: "text-sm font-medium text-red-600 hover:text-red-700 dark:text-red-400" %>
                </div>
              <% end %>
            <% elsif @team_template_links.empty? %>
              <p class="text-sm text-slate-500 dark:text-slate-400">Noch keine Links hinterlegt.</p>
            <% end %>
          </div>

          <%= form_with model: CampTeamLink.new, url: admin_camp_team_links_path(@camp, @camp_team), class: "mt-5 grid gap-4 sm:grid-cols-[1fr_1.3fr_auto]" do |f| %>
            <div>
              <%= f.label :title, "Titel", class: "mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300" %>
              <%= f.text_field :title, class: "w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-slate-900 outline-none transition focus:border-blue-400 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
            </div>
            <div>
              <%= f.label :url, "Link", class: "mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300" %>
              <%= f.url_field :url, placeholder: "https://...", class: "w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-slate-900 outline-none transition focus:border-blue-400 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
            </div>
            <div class="flex items-end">
              <%= f.submit "Hinzufügen", class: "inline-flex rounded-lg bg-red-600 px-4 py-2.5 text-sm font-medium text-white hover:bg-red-700" %>
            </div>
          <% end %>
        </div>
      <% elsif @section == "description" %>
        <div class="rounded-2xl bg-white p-6 shadow dark:bg-slate-800">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Aufgabenbeschreibung</h3>
              <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
                Dieser Text ist zentral für den Team-Typ hinterlegt und gilt für alle gleich benannten Teams.
              </p>
            </div>
            <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700 dark:bg-slate-900/60 dark:text-slate-300">
              Vorlage: <%= @camp_team.team_template&.name || @camp_team.name %>
            </span>
          </div>

          <%= form_with model: @camp_team, url: admin_camp_team_path(@camp, @camp_team), method: :patch, class: "mt-5 space-y-5" do |f| %>
            <%= hidden_field_tag :from, "team_page" %>
            <%= hidden_field_tag :section, "description" %>
            <%= hidden_field_tag :return_to, admin_camp_team_page_path(@camp, @camp_team, section: "description") %>
            <div>
              <%= f.label :custom_description, "Camp-spezifische Team-Beschreibung", class: "mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300" %>
              <%= f.text_area :custom_description, value: @camp_team.custom_description.presence || @camp_team.team_template&.description, rows: 14, placeholder: "Leer lassen, um den zentralen Default zu verwenden.", class: "w-full rounded-lg border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition focus:border-blue-400 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
            </div>
            <% if @camp_team.supports_responsible_description? %>
              <div>
                <%= f.label :custom_responsible_description, "Camp-spezifische Zusatzbeschreibung für Verantwortliche", class: "mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300" %>
                <%= f.text_area :custom_responsible_description, value: @camp_team.custom_responsible_description.presence || @camp_team.team_template&.responsible_description, rows: 10, placeholder: "Leer lassen, um den zentralen Default zu verwenden.", class: "w-full rounded-lg border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition focus:border-blue-400 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
              </div>
            <% end %>
            <div class="rounded-2xl border border-slate-200 bg-slate-50/70 px-4 py-4 text-sm text-slate-600 dark:border-slate-700 dark:bg-slate-900/30 dark:text-slate-300">
              Der zentrale Default wird unter <%= link_to "Teamverwaltung", admin_team_templates_path, class: "font-medium text-red-600 hover:text-red-700 dark:text-red-400" %> gepflegt. Alles, was du hier einträgst, gilt nur für <span class="font-medium"><%= @camp.name %></span>.
            </div>
            <div class="flex justify-end">
              <%= f.submit "Aufgabenbeschreibung speichern", class: "inline-flex rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700" %>
            </div>
          <% end %>
        </div>
      <% elsif @section == "todos" %>
        <div class="rounded-2xl bg-white p-6 shadow dark:bg-slate-800">
          <div>
            <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100">ToDo-Liste</h3>
            <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
              Verwalte hier die camp-spezifischen Aufgaben des Teams.
            </p>
          </div>

          <div class="mt-5 space-y-3">
            <% if @camp_team_todos.any? %>
              <% @camp_team_todos.each do |todo| %>
                <div class="flex items-center justify-between gap-4 rounded-lg border border-slate-200 px-4 py-3 dark:border-slate-700">
                  <div class="flex items-center gap-3">
                    <%= form_with model: todo, url: admin_camp_team_todo_path(@camp, @camp_team, todo), method: :patch do |f| %>
                      <%= f.check_box :completed, { checked: todo.completed, onchange: "this.form.requestSubmit()", class: "h-4 w-4 rounded border-slate-300 text-blue-500 focus:ring-blue-400 dark:border-slate-600 dark:bg-slate-900" }, "1", "0" %>
                    <% end %>
                    <p class="<%= todo.completed? ? 'text-slate-400 line-through dark:text-slate-500' : 'text-slate-900 dark:text-slate-100' %>">
                      <%= todo.title %>
                    </p>
                  </div>
                  <%= link_to "Entfernen", admin_camp_team_todo_path(@camp, @camp_team, todo), data: { turbo_method: :delete, turbo_confirm: "ToDo wirklich entfernen?" }, class: "text-sm font-medium text-red-600 hover:text-red-700 dark:text-red-400" %>
                </div>
              <% end %>
            <% else %>
              <p class="text-sm text-slate-500 dark:text-slate-400">Noch keine ToDos angelegt.</p>
            <% end %>
          </div>

          <%= form_with model: CampTeamTodo.new, url: admin_camp_team_todos_path(@camp, @camp_team), class: "mt-5 flex gap-3" do |f| %>
            <%= f.text_field :title, placeholder: "Neue Aufgabe...", class: "flex-1 rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-slate-900 outline-none transition focus:border-blue-400 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
            <%= f.submit "Hinzufügen", class: "inline-flex rounded-lg bg-red-600 px-4 py-2.5 text-sm font-medium text-white hover:bg-red-700" %>
          <% end %>
        </div>
      <% elsif @section == "downloads" %>
        <%= render "shared/download_items_list",
          default_items: @team_template_download_items,
          default_manage_path: admin_team_template_path(@camp_team.team_template),
          local_items: @camp_team_download_items,
          can_manage_local: @can_manage_local_downloads,
          create_local_url: admin_camp_team_download_items_path(@camp, @camp_team),
          local_item_path_builder: ->(item) { admin_camp_team_download_item_path(@camp, @camp_team, item) },
          local_title: "Camp-Dateien",
          local_description: "Dateien, die nur für dieses Team in diesem Camp gelten.",
          local_badge: "campbezogen" %>
      <% elsif @section == "sport_plan" %>
        <div class="relative left-1/2 w-screen max-w-none -translate-x-1/2 px-4 sm:px-6 xl:px-8">
        <div class="space-y-4">
          <div class="rounded-2xl bg-white p-4 shadow dark:bg-slate-800">
            <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
              <div>
                <h3 class="text-sm font-semibold text-slate-900 dark:text-slate-100">Eingeteilte Mitarbeiter</h3>
                <p class="mt-0.5 text-xs text-slate-500 dark:text-slate-400">Kompakter Teamüberblick für den Sportplan.</p>
              </div>
              <div class="flex flex-wrap gap-2">
                <% if @assigned_applications.any? %>
                  <% @assigned_applications.each do |application| %>
                    <div class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-slate-50 px-3 py-1.5 text-xs font-medium text-slate-700 dark:border-slate-700 dark:bg-slate-900/40 dark:text-slate-200">
                      <span><%= [application.user.first_name, application.user.last_name].compact.join(" ").presence || application.user.email %></span>
                      <% if application.assigned_as_responsible? %>
                        <span class="rounded-full bg-amber-100 px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-amber-700 dark:bg-amber-900/60 dark:text-amber-200">V</span>
                      <% end %>
                    </div>
                  <% end %>
                <% else %>
                  <p class="text-xs text-slate-500 dark:text-slate-400">Noch niemand eingeteilt.</p>
                <% end %>
              </div>
            </div>
          </div>

          <div class="rounded-2xl bg-white p-6 shadow dark:bg-slate-800">
          <div>
            <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Sportplan</h3>
            <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
              Freisport und Pflichsport im schnellen Wochenblick pro Camptag.
            </p>
          </div>

          <% if @camp.day_range.blank? %>
            <div class="mt-5 rounded-2xl border border-dashed border-slate-300 px-4 py-6 text-sm text-slate-500 dark:border-slate-700 dark:text-slate-400">
              Bitte pflegt zuerst beim Camp ein Von- und Bis-Datum.
            </div>
          <% else %>
            <div class="mt-5">
              <div class="grid overflow-hidden rounded-2xl border border-slate-200 bg-slate-50/70 dark:border-slate-700 dark:bg-slate-900/30" style="grid-template-columns: repeat(<%= @camp_sport_day_plans.size %>, minmax(0, 1fr));">
                <% @camp_sport_day_plans.each do |sport_day_plan| %>
                  <div class="<%= sport_day_plan == @camp_sport_day_plans.first ? '' : 'border-l border-slate-200 dark:border-slate-700' %> p-4">
                    <div class="border-b border-slate-200 pb-3 dark:border-slate-700">
                      <p class="text-sm font-semibold text-slate-900 dark:text-slate-100"><%= l(sport_day_plan.planned_on, format: "%A") %></p>
                      <p class="text-xs text-slate-500 dark:text-slate-400"><%= l(sport_day_plan.planned_on, format: "%d.%m.%Y") %></p>
                    </div>

