              </div>
              <div>
                <%= f.label :camp_sleeping_place_id, "Schlafplatz", class: "mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300" %>
                <%= f.select :camp_sleeping_place_id, options_for_select([["Noch nicht zugewiesen", nil]] + @camp_sleeping_places.map { |place| [place.name, place.id] }), {}, class: "w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm text-slate-900 outline-none transition focus:border-blue-400 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
              </div>
              <div>
                <%= f.label :notes, "Hinweis", class: "mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300" %>
                <%= f.text_field :notes, placeholder: "z. B. reist später an", class: "w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-slate-900 outline-none transition focus:border-blue-400 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
              </div>
              <div class="flex items-end">
                <%= f.submit "Hinzufügen", class: "inline-flex rounded-lg bg-red-600 px-4 py-2.5 text-sm font-medium text-white hover:bg-red-700" %>
              </div>
            <% end %>

            <div class="mt-5 space-y-3">
              <% if @camp_room_people.any? %>
                <% @camp_room_people.each do |person| %>
                  <%= form_with model: person, url: admin_camp_room_person_path(@camp, @camp_team, person), method: :patch, class: "grid gap-3 rounded-xl border border-slate-200 px-4 py-3 lg:grid-cols-3 lg:items-center dark:border-slate-700" do |f| %>
                    <%= f.text_field :name, class: "w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm text-slate-900 outline-none transition focus:border-blue-400 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
                    <%= f.select :kind, options_for_select(CampRoomPerson::KINDS.map { |key, label| [label, key] }, person.kind), {}, class: "w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm text-slate-900 outline-none transition focus:border-blue-400 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
                    <%= f.select :related_camp_application_id, options_for_select([["Niemandem direkt zugeordnet", nil]] + @camp_room_candidates.map { |application| [[application.user.first_name, application.user.last_name].compact.join(" "), application.id] }, person.related_camp_application_id), {}, class: "w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm text-slate-900 outline-none transition focus:border-blue-400 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
                    <%= f.select :camp_sleeping_place_id, options_for_select([["Noch nicht zugewiesen", nil]] + @camp_sleeping_places.map { |place| [place.name, place.id] }, person.camp_sleeping_place_id), {}, class: "w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm text-slate-900 outline-none transition focus:border-blue-400 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
                    <%= f.text_field :notes, placeholder: "Hinweis", class: "w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm text-slate-900 outline-none transition focus:border-blue-400 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
                    <div class="flex justify-end gap-2">
                      <%= f.submit "Speichern", class: "inline-flex rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-700" %>
                      <%= link_to "Entfernen", admin_camp_room_person_path(@camp, @camp_team, person), data: { turbo_method: :delete, turbo_confirm: "Diese Person wirklich entfernen?" }, class: "inline-flex rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700" %>
                    </div>
                  <% end %>
                <% end %>
              <% else %>
                <p class="text-sm text-slate-500 dark:text-slate-400">Noch keine zusätzlichen Personen erfasst.</p>
              <% end %>
            </div>
          </div>
        </div>
      <% elsif @section == "shopping" %>
