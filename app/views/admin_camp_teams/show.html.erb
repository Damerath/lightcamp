            <div class="mt-5 space-y-3">
              <% @camp_room_candidates.each do |application| %>
                <%= form_with model: application, url: admin_camp_sleeping_assignment_path(@camp, @camp_team, application), method: :patch, class: "grid gap-3 rounded-xl border border-slate-200 px-4 py-3 md:grid-cols-[minmax(0,1fr)_15rem_auto] md:items-center dark:border-slate-700" do |f| %>
                  <div>
                    <p class="font-medium text-slate-900 dark:text-slate-100"><%= [application.user.first_name, application.user.last_name].compact.join(" ") %></p>
                    <p class="text-sm text-slate-500 dark:text-slate-400">
                      <%= application.assigned_camp_team&.name || "-" %>
                      <% if application.assigned_as_responsible? %>
                        · verantwortlich
                      <% end %>
                    </p>
                    <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">
                      Aktuell: <%= application.camp_sleeping_place&.name || "Nicht zugewiesen" %>
                    </p>
                  </div>
                  <div>
                    <%= f.select :camp_sleeping_place_id, options_for_select([["Nicht zugewiesen", nil]] + @camp_sleeping_places.map { |place| ["#{place.name} (#{place.occupancy_count}/#{place.capacity})", place.id] }, application.camp_sleeping_place_id), {}, class: "w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm text-slate-900 outline-none transition focus:border-blue-400 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
                  </div>
                  <div class="flex justify-end">
                    <%= f.submit "Speichern", class: "inline-flex rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700" %>
                  </div>
                <% end %>
              <% end %>
            </div>
          </div>

          <div class="rounded-2xl bg-white p-6 shadow dark:bg-slate-800">
            <div>
              <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Weitere Personen</h3>
