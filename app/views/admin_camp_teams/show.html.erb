              </p>
            </div>

            <%= form_with model: CampRoomPerson.new, url: admin_camp_room_people_path(@camp, @camp_team), class: "mt-5 grid gap-4 lg:grid-cols-4" do |f| %>
              <div>
                <%= f.label :name, "Name", class: "mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300" %>
                <%= f.text_field :name, placeholder: "z. B. Anna Müller", class: "w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-slate-900 outline-none transition focus:border-blue-400 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
              </div>
              <div>
                <%= f.label :kind, "Typ", class: "mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300" %>
                <%= f.select :kind, options_for_select(CampRoomPerson::KINDS.map { |key, label| [label, key] }), {}, class: "w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm text-slate-900 outline-none transition focus:border-blue-400 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
              </div>
              <div>
                <%= f.label :related_camp_application_id, "Gehört zu", class: "mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300" %>
