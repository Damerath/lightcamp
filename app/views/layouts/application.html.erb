<!DOCTYPE html>
<html>
  <head>
    <title>Lightcamp HQ</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script src="https://unpkg.com/lucide@latest"></script>
  </head>

  <body class="bg-slate-100 text-slate-900 dark:bg-slate-900 dark:text-slate-100">
    <div
      data-controller="confirm-modal"
      class="hidden"
    >
      <div
        data-confirm-modal-target="backdrop"
        data-action="click->confirm-modal#closeFromBackdrop"
        class="fixed inset-0 z-[70] flex items-center justify-center bg-slate-950/60 px-4 opacity-0 transition duration-150"
      >
        <div
          data-confirm-modal-target="panel"
          class="w-full max-w-md rounded-2xl border border-slate-200 bg-white p-6 shadow-2xl opacity-0 translate-y-4 scale-95 transition duration-150 dark:border-slate-700 dark:bg-slate-800"
        >
          <div class="flex items-start gap-3">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-red-100 text-red-700 dark:bg-red-950/60 dark:text-red-300">
              !
            </div>
            <div class="min-w-0">
              <h3 data-confirm-modal-target="title" class="text-lg font-semibold text-slate-900 dark:text-slate-100">
                Bitte bestätigen
              </h3>
              <p data-confirm-modal-target="message" class="mt-2 text-sm leading-6 text-slate-600 dark:text-slate-300"></p>
            </div>
          </div>

          <div class="mt-6 flex justify-end gap-3">
            <button
              type="button"
              data-confirm-modal-target="cancelButton"
              class="inline-flex rounded-lg border border-slate-300 px-4 py-2.5 text-sm font-medium text-slate-700 transition hover:bg-slate-100 focus:outline-none focus:ring-2 focus:ring-slate-300 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-700"
            >
              Abbrechen
            </button>
            <button
              type="button"
              data-confirm-modal-target="confirmButton"
              class="inline-flex rounded-lg bg-red-600 px-4 py-2.5 text-sm font-medium text-white transition hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-400"
            >
              Bestätigen
            </button>
          </div>
        </div>
      </div>
    </div>

    <header class="bg-white dark:bg-slate-800 shadow">
      <div class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-4 px-4 py-4 sm:px-6">
        
        <div class="flex items-center gap-3">
          <%= link_to root_path do %>
            <%= image_tag("lightcamp_logo.png", alt: "Lightcamp Logo", class: "h-9 w-auto block dark:hidden") %>
            <%= image_tag("lightcamp_logo_dark.png", alt: "Lightcamp Logo", class: "h-9 w-auto hidden dark:block") %>
          <% end %>
          <span class="text-xl font-semibold text-slate-600 dark:text-slate-300">HQ</span>
        </div>

        <% if user_signed_in? %>
          <nav class="flex max-w-full flex-wrap items-center justify-end gap-x-4 gap-y-2 text-sm font-medium sm:gap-x-6">
            <%= link_to "Dashboard", root_path,
              class: "text-sm font-medium #{current_page?(root_path) ? 'text-red-600' : 'text-slate-600 dark:text-slate-300 hover:text-blue-400'}" %>
            <%= link_to "Meine Camps", camps_path,
              class: "text-sm font-medium #{current_page?(camps_path) ? 'text-red-600' : 'text-slate-600 dark:text-slate-300 hover:text-blue-400'}" %>
            <a href="#" class="hidden text-slate-700 hover:text-blue-400 sm:inline">Leitung</a>
            <% if current_user.admin? %>
              <%= link_to "Admin", admin_path,
                class: "text-sm font-medium #{current_page?(admin_path) ? 'text-red-600' : 'text-slate-600 dark:text-slate-300 hover:text-blue-400'}" %>
            <% end %>
            <div class="relative" data-controller="menu">
              <button type="button" data-action="click->menu#toggle">
                <span data-menu-target="icon" class="text-slate-300 transition">
                  ☰
                </span>
              </button>

              <div data-menu-target="menu" class="hidden absolute right-0 mt-2 w-40 rounded-lg bg-white shadow dark:bg-slate-800">
                <%= link_to "Profil", profile_path, class: "block px-4 py-2 text-sm hover:bg-slate-100 dark:hover:bg-slate-700" %>

                <%= button_to "Logout", destroy_user_session_path, method: :delete,
                  class: "w-full text-left px-4 py-2 text-sm hover:bg-slate-100 dark:hover:bg-slate-700" %>
              </div>
            </div>
          </nav>
        <% end %>
      </div>
    </header>

    <main class="mx-auto max-w-5xl px-6 py-8">
      <%= yield %>
    </main>
    <div class="fixed bottom-6 left-1/2 text-center transform -translate-x-1/2 z-50 space-y-3 w-full max-w-5xl">
      <% if notice %>
        <div
          data-controller="flash"
          class="rounded-lg bg-green-300 px-4 py-3 text-slate-900 shadow-lg transition duration-300 ease-out"
        >
          <%= notice %>
        </div>
      <% end %>

      <% if alert %>
        <div
          data-controller="flash"
          class="rounded-lg bg-red-300 px-4 py-3 text-slate-900 shadow-lg transition duration-300 ease-out"
        >
          <%= alert %>
        </div>
      <% end %>
    </div>
    <script>
      lucide.createIcons();
    </script>
  </body>
</html>
