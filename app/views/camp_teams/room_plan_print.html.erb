<div class="print-toolbar mb-4 flex items-center justify-between gap-4">
  <div>
    <h1 class="text-2xl font-bold text-slate-900">Zimmereinteilung</h1>
    <p class="mt-1 text-sm text-slate-500">
      <%= @camp.name %> · <%= @camp_team.workspace_label %>
    </p>
  </div>
  <div class="flex gap-3">
    <% back_path = current_user&.admin? ? admin_camp_team_page_path(@camp, @camp_team, section: "room_plan") : camp_team_page_path(@camp, @camp_team, section: "room_plan") %>
    <%= link_to "Zurück", back_path, class: "rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100" %>
    <button onclick="window.print()" class="rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700">Drucken</button>
  </div>
</div>

<div class="grid gap-4 print:grid-cols-2 md:grid-cols-2 xl:grid-cols-3">
  <% @camp_sleeping_places.each do |place| %>
    <% assigned_people = @camp_room_assignments_by_place_id[place.id] || [] %>
    <% extra_people = @camp_room_people_by_place_id[place.id] || [] %>
    <section class="overflow-hidden rounded-2xl border border-slate-300 bg-white">
      <div class="flex items-start justify-between gap-3 border-b border-slate-300 bg-slate-50 px-4 py-3">
        <div>
          <div class="flex items-center gap-2">
            <h2 class="text-base font-semibold text-slate-900"><%= place.name %></h2>
            <% if place.family_only? %>
              <span class="rounded-full bg-amber-100 px-2 py-0.5 text-[11px] font-medium text-amber-700">Familie</span>
            <% elsif place.custom? %>
              <span class="rounded-full bg-sky-100 px-2 py-0.5 text-[11px] font-medium text-sky-700">Extra</span>
            <% end %>
          </div>
          <p class="mt-1 text-xs text-slate-500">
            <%= place.capacity %> Plätze<%= place.details.present? && !place.family_only? ? " · #{place.details}" : "" %>
          </p>
        </div>
        <span class="rounded-full px-2.5 py-1 text-xs font-medium <%= (assigned_people.size + extra_people.size) > place.capacity ? 'bg-red-100 text-red-700' : 'bg-emerald-100 text-emerald-700' %>">
          <%= assigned_people.size + extra_people.size %>/<%= place.capacity %>
        </span>
      </div>

      <div class="space-y-2 px-4 py-4">
        <% assigned_people.each do |application| %>
          <div class="rounded-lg border border-slate-200 px-3 py-2">
            <p class="text-sm font-medium text-slate-900"><%= [application.user.first_name, application.user.last_name].compact.join(" ") %></p>
            <p class="text-xs text-slate-500"><%= application.assigned_camp_team&.name || "-" %></p>
          </div>
        <% end %>

        <% extra_people.each do |person| %>
          <div class="rounded-lg border border-sky-200 bg-sky-50/70 px-3 py-2">
            <p class="text-sm font-medium text-slate-900"><%= person.name %></p>
            <p class="text-xs text-slate-500">
              <%= person.kind_label %><%= person.related_camp_application&.user.present? ? " · zu #{person.related_camp_application.user.first_name} #{person.related_camp_application.user.last_name}" : "" %>
            </p>
          </div>
        <% end %>

        <% if assigned_people.empty? && extra_people.empty? %>
          <p class="text-sm text-slate-500">Noch niemand zugewiesen.</p>
        <% end %>
      </div>
    </section>
  <% end %>
</div>

<% if @unassigned_room_candidates.any? || @unassigned_room_people.any? %>
  <section class="mt-6 overflow-hidden rounded-2xl border border-slate-300 bg-white">
    <div class="border-b border-slate-300 bg-slate-50 px-4 py-3">
      <h2 class="text-base font-semibold text-slate-900">Noch nicht zugewiesen</h2>
    </div>
    <div class="grid gap-3 px-4 py-4 md:grid-cols-2">
      <% @unassigned_room_candidates.each do |application| %>
        <div class="rounded-lg border border-slate-200 px-3 py-2">
          <p class="text-sm font-medium text-slate-900"><%= [application.user.first_name, application.user.last_name].compact.join(" ") %></p>
          <p class="text-xs text-slate-500"><%= application.assigned_camp_team&.name || "-" %></p>
        </div>
      <% end %>
      <% @unassigned_room_people.each do |person| %>
        <div class="rounded-lg border border-sky-200 bg-sky-50/70 px-3 py-2">
          <p class="text-sm font-medium text-slate-900"><%= person.name %></p>
          <p class="text-xs text-slate-500">
            <%= person.kind_label %><%= person.related_camp_application&.user.present? ? " · zu #{person.related_camp_application.user.first_name} #{person.related_camp_application.user.last_name}" : "" %>
          </p>
        </div>
      <% end %>
    </div>
  </section>
<% end %>
