<div class="space-y-6">
  <div class="print-toolbar flex items-center justify-between gap-4 border-b border-slate-200 pb-4">
    <div>
      <p class="text-sm font-medium uppercase tracking-wide text-slate-500">
        <%= @camp.year.name %> · <%= @camp.name %>
      </p>
      <h1 class="text-3xl font-bold text-slate-900">Turniervorlage Sport</h1>
      <p class="mt-1 text-sm text-slate-600"><%= @camp_sport_tournament_plan.round_note %></p>
    </div>

    <div class="flex items-center gap-3">
      <button type="button" onclick="window.print()" class="inline-flex rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700">
        Drucken
      </button>
      <% back_path = current_user&.admin? ? admin_camp_team_page_path(@camp, @camp_team, section: "sport_plan") : camp_team_page_path(@camp, @camp_team, section: "sport_plan") %>
      <%= link_to "Zurueck", back_path, class: "inline-flex rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100" %>
    </div>
  </div>

  <div class="overflow-hidden rounded-2xl border border-slate-300">
    <table class="min-w-full border-collapse text-sm">
      <thead class="bg-slate-100">
        <tr>
          <th class="border border-slate-300 px-3 py-2 text-left font-semibold text-slate-900">Zeit</th>
          <th class="border border-slate-300 px-3 py-2 text-right font-semibold text-slate-900">Runde</th>
          <% 5.times do |index| %>
            <th class="border border-slate-300 px-3 py-2 text-left font-semibold text-slate-900"><%= @camp_sport_tournament_plan.station_name(index + 1) %></th>
          <% end %>
        </tr>
      </thead>
      <tbody>
        <% @camp_sport_tournament_plan.round_rows.each do |row| %>
          <tr class="align-top">
            <td class="border border-slate-300 px-3 py-2 font-medium text-slate-900"><%= row[:time_label] %></td>
            <td class="border border-slate-300 px-3 py-2 text-right font-medium text-slate-900"><%= row[:round] %></td>
            <% row[:slots].each do |slot| %>
              <td class="border border-slate-300 px-3 py-2 text-slate-800"><%= slot[:value] %></td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
