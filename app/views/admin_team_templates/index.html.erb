<div class="space-y-8">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h2 class="text-2xl font-bold">Teamverwaltung</h2>
      <p class="mt-1 text-slate-600 dark:text-slate-400">
        Lege hier die zentralen Defaults für alle Teamseiten fest.
      </p>
    </div>
    <%= link_to "Zur Admin-Übersicht", admin_path, class: "inline-flex rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-200 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-700" %>
  </div>

  <% if @active_year.present? %>
    <div class="rounded-2xl border border-sky-200 bg-sky-50 px-5 py-4 text-sm text-sky-900 dark:border-sky-900/60 dark:bg-sky-950/20 dark:text-sky-100">
      Aktives Jahr: <span class="font-semibold"><%= @active_year.name %></span>. Bei „Für folgende Jahre speichern“ werden lokale Überschreibungen nur für spätere Jahre auf den neuen Default zurückgesetzt.
    </div>
  <% end %>

  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
    <% @team_templates.each do |template| %>
      <%= link_to admin_team_template_path(template), class: "block rounded-2xl bg-white p-5 shadow transition hover:ring-1 hover:ring-blue-400 dark:bg-slate-800" do %>
        <div class="flex items-start justify-between gap-3">
          <div>
            <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100"><%= template.name %></h3>
            <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
              <%= template.supports_responsible_description? ? "Mit Zusatzbeschreibung für Verantwortliche." : "Mit allgemeiner Standardbeschreibung." %>
            </p>
          </div>
          <span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs font-medium text-slate-600 dark:bg-slate-900/60 dark:text-slate-300">
            Default
          </span>
        </div>

        <div class="mt-4 text-sm text-slate-500 dark:text-slate-400">
          <%= truncate(template.description.to_s.presence || "Noch keine Beschreibung hinterlegt.", length: 150) %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
