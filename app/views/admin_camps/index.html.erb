<div class="space-y-8">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h2 class="text-2xl font-bold">Campverwaltung</h2>
      <p class="mt-1 text-slate-600 dark:text-slate-400">
        Verwalte alle Camps nach Jahr.
      </p>
    </div>
    <%= link_to "Zur Admin-Übersicht", admin_path, class: "inline-flex rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-200 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-700" %>
  </div>

  <div>
    <%= link_to "Jahr hinzufügen", admin_camps_path(modal: "new_year"), class: "inline-flex rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-red-700" %>
    <%= link_to "Camp hinzufügen", admin_camps_path(modal: "new_camp"), class: "inline-flex rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-red-700" %>  </div>
  <% @years.each do |year| %>
    <div>
      <h3 class="flex items-start justify-between text-lg font-semibold flex items-center gap-2">
        
        <div class="flex items-center gap-2">
          <%= year.name %>
          <%= link_to admin_camps_path(modal: "edit_year", year_id: year.id), class: "text-slate-400 hover:text-red-600 transition" do %> 
            <i data-lucide="pencil" class="w-4 h-4"></i>
          <% end %>
          <% if year.registration_open? %>
            <span class="rounded-full bg-green-100 px-2 py-1 text-xs font-medium text-green-700 dark:bg-green-900 dark:text-green-200">
              Anmeldung aktiv
            </span>
          <% end %>
        </div>
        <%= button_to(
          year.registration_open? ? "Anmeldung deaktivieren" : "Anmeldung aktivieren",
          toggle_year_registration_path(year),
          method: :patch,
          class: "inline-flex rounded-lg border px-3 py-1.5 text-sm font-medium #{year.registration_open? ? 'border-red-300 text-red-600 hover:bg-red-50 dark:border-red-700 dark:text-red-400 dark:hover:bg-red-950' : 'border-slate-300 text-slate-700 hover:bg-slate-200 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-700'}"
        ) %>
        
      </h3>
      <br>
      <% cols =
        case year.camps.count
        when 1 then "sm:grid-cols-1"
        when 2 then "sm:grid-cols-2"
        else "sm:grid-cols-3"
        end
      %>

      <div class="grid gap-4 <%= cols %>">
        <% year.camps.each do |camp| %>
          <div class="flex items-start justify-between group rounded-lg bg-white hover:ring-1 hover:ring-blue-400 dark:bg-slate-800 p-5 shadow">
            <h4 class="font-semibold text-slate-900 dark:text-slate-100 flex items-center gap-2 group">
              <%= camp.name %>
              <%= link_to admin_camps_path(modal: "edit_camp", camp_id: camp.id), class: "opacity-0 group-hover:opacity-100 text-slate-400 hover:text-red-600 transition" do %>
                <i data-lucide="pencil" class="w-4 h-4"></i>
              <% end %>
              </h4>
            <div class="flex items-center gap-2">
              <%= link_to "Teamview", admin_camp_teams_path(camp), class: "inline-flex rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-100 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-700" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
  <% if params[:modal] == "new_year" %>
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm px-4">
      <div class="w-full max-w-md rounded-2xl bg-white p-6 shadow-xl dark:bg-slate-800 text-center">
        <div class="mt-2">
            <div class="flex justify-end">
              <%= link_to "×", admin_camps_path, class: "text-2xl leading-none text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white" %>
            </div>
          <h3 class="text-xl font-bold text-slate-900 dark:text-slate-100">
            Jahr hinzufügen
          </h3>
          <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
            Lege ein neues Camp-Jahr an.
          </p>
        </div>

        <!-- Formular -->
        <div class="mt-6">
          <%= form_with model: Year.new, url: years_path, class: "space-y-4 text-left" do |f| %>
            <div>
              <%= f.label :name, "Jahr", class: "mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300" %>
              <%= f.text_field :name, placeholder: "z. B. 2027", class: "w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-slate-900 outline-none transition focus:border-red-600 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
            </div>

            <div class="flex justify-center gap-3 pt-2">
              <%= link_to "Abbrechen", admin_camps_path, class: "inline-flex rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-100 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-700" %>
              <%= f.submit "Jahr erstellen", class: "inline-flex rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-red-700" %>
            </div>
          <% end %>
        </div>

      </div>

    </div>
  <% end %>
  <% if params[:modal] == "edit_year" && @year %>
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm px-4">
      
      <div class="w-full max-w-md rounded-2xl bg-white p-6 shadow-xl dark:bg-slate-800 text-center">
        
        <div class="flex justify-end">
          <%= link_to "×", admin_camps_path, class: "text-2xl leading-none text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white" %>
        </div>

        <div class="mt-2">
          <h3 class="text-xl font-bold text-slate-900 dark:text-slate-100">
            Jahr bearbeiten
          </h3>
        </div>

        <div class="mt-6">
          <%= form_with model: @year, url: year_path(@year), method: :patch, class: "space-y-4 text-left" do |f| %>
            
            <div>
              <%= f.label :name, "Jahr", class: "mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300" %>
              <%= f.text_field :name, class: "w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-slate-900 outline-none transition focus:border-red-600 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
            </div>

            <div class="flex justify-center gap-3 pt-2">
              <%= link_to "Abbrechen", admin_camps_path, class: "inline-flex rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-200 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-700" %>
              <%= f.submit "Speichern", class: "inline-flex rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700" %>
            </div>

          <% end %>
        </div>

      </div>

    </div>
  <% end %>
  <% if params[:modal] == "new_camp" %>
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm px-4">
      <div class="w-full max-w-xl rounded-2xl bg-white p-6 text-center shadow-xl dark:bg-slate-800">
        <div class="flex justify-end">
          <%= link_to "×", admin_camps_path, class: "text-2xl leading-none text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white" %>
        </div>

        <div class="mt-2">
          <h3 class="text-xl font-bold text-slate-900 dark:text-slate-100">
            Camp hinzufügen
          </h3>
          <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
            Lege ein neues Camp für ein Jahr an.
          </p>
        </div>

        <div class="mt-6">
          <%= form_with model: Camp.new, url: camps_path, class: "space-y-4 text-left" do |f| %>
            <div>
              <%= f.label :name, "Camp-Name", class: "mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300" %>
              <%= f.text_field :name, placeholder: "z. B. LC1", class: "w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-slate-900 outline-none transition focus:border-red-600 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
            </div>

            <div>
              <%= f.label :year_id, "Jahr", class: "mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300" %>
              <%= f.collection_select :year_id, Year.order(name: :desc), :id, :name, { prompt: "Jahr auswählen" }, class: "w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-slate-900 outline-none transition focus:border-red-600 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
            </div>

            <div class="grid gap-4 md:grid-cols-2">
              <div>
                <%= f.label :start_on, "Von", class: "mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300" %>
                <div class="relative" data-controller="datepicker">
                  <%= f.hidden_field :start_on, value: nil, data: { datepicker_target: "value" } %>
                  <input
                    type="text"
                    value=""
                    class="w-full min-w-0 cursor-pointer rounded-lg border border-slate-300 bg-white px-4 py-2.5 pr-11 text-slate-900 outline-none transition focus:border-red-600 focus:ring-0 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100"
                    autocomplete="off"
                    placeholder="TT.MM.JJJJ"
                    data-datepicker-target="input"
                    data-action="click->datepicker#open focus->datepicker#open"
                  >
                  <button type="button" class="absolute inset-y-0 right-0 flex items-center pr-4 text-slate-400 dark:text-slate-500" data-action="click->datepicker#open">
                    <i data-lucide="calendar-days" class="h-4 w-4"></i>
                  </button>
                </div>
              </div>

              <div>
                <%= f.label :end_on, "Bis", class: "mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300" %>
                <div class="relative" data-controller="datepicker">
                  <%= f.hidden_field :end_on, value: nil, data: { datepicker_target: "value" } %>
                  <input
                    type="text"
                    value=""
                    class="w-full min-w-0 cursor-pointer rounded-lg border border-slate-300 bg-white px-4 py-2.5 pr-11 text-slate-900 outline-none transition focus:border-red-600 focus:ring-0 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100"
                    autocomplete="off"
                    placeholder="TT.MM.JJJJ"
                    data-datepicker-target="input"
                    data-action="click->datepicker#open focus->datepicker#open"
                  >
                  <button type="button" class="absolute inset-y-0 right-0 flex items-center pr-4 text-slate-400 dark:text-slate-500" data-action="click->datepicker#open">
                    <i data-lucide="calendar-days" class="h-4 w-4"></i>
                  </button>
                </div>
              </div>
            </div>

            <div class="flex justify-center gap-3 pt-2">
              <%= link_to "Abbrechen", admin_camps_path, class: "inline-flex rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-100 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-700" %>
              <%= f.submit "Camp erstellen", class: "inline-flex rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-red-700" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
  <% if params[:modal] == "edit_camp" && @camp %>
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm px-4">
      
      <div class="w-full max-w-xl rounded-2xl bg-white p-6 shadow-xl dark:bg-slate-800 text-center">
        
        <div class="flex justify-end">
          <%= link_to "×", admin_camps_path, class: "text-2xl leading-none text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white" %>
        </div>

        <div class="mt-2">
          <h3 class="text-xl font-bold text-slate-900 dark:text-slate-100">
            Camp bearbeiten
          </h3>
        </div>

        <div class="mt-6">
          <%= form_with model: @camp, url: camp_path(@camp), method: :patch, class: "space-y-4 text-left" do |f| %>
            
            <div>
              <%= f.label :name, "Camp-Name", class: "mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300" %>
              <%= f.text_field :name, class: "w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-slate-900 outline-none transition focus:border-red-600 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
            </div>

            <div>
              <%= f.label :year_id, "Jahr", class: "mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300" %>
              <%= f.collection_select :year_id, Year.order(name: :desc), :id, :name, {}, class: "w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-slate-900 outline-none transition focus:border-red-600 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100" %>
            </div>

            <div class="grid gap-4 md:grid-cols-2">
              <div>
                <%= f.label :start_on, "Von", class: "mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300" %>
                <div class="relative" data-controller="datepicker">
                  <%= f.hidden_field :start_on, value: @camp.start_on&.strftime("%Y-%m-%d"), data: { datepicker_target: "value" } %>
                  <input
                    type="text"
                    value="<%= @camp.start_on&.strftime('%d.%m.%Y') %>"
                    class="w-full min-w-0 cursor-pointer rounded-lg border border-slate-300 bg-white px-4 py-2.5 pr-11 text-slate-900 outline-none transition focus:border-red-600 focus:ring-0 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100"
                    autocomplete="off"
                    placeholder="TT.MM.JJJJ"
                    data-datepicker-target="input"
                    data-action="click->datepicker#open focus->datepicker#open"
                  >
                  <button type="button" class="absolute inset-y-0 right-0 flex items-center pr-4 text-slate-400 dark:text-slate-500" data-action="click->datepicker#open">
                    <i data-lucide="calendar-days" class="h-4 w-4"></i>
                  </button>
                </div>
              </div>

              <div>
                <%= f.label :end_on, "Bis", class: "mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300" %>
                <div class="relative" data-controller="datepicker">
                  <%= f.hidden_field :end_on, value: @camp.end_on&.strftime("%Y-%m-%d"), data: { datepicker_target: "value" } %>
                  <input
                    type="text"
                    value="<%= @camp.end_on&.strftime('%d.%m.%Y') %>"
                    class="w-full min-w-0 cursor-pointer rounded-lg border border-slate-300 bg-white px-4 py-2.5 pr-11 text-slate-900 outline-none transition focus:border-red-600 focus:ring-0 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100"
                    autocomplete="off"
                    placeholder="TT.MM.JJJJ"
                    data-datepicker-target="input"
                    data-action="click->datepicker#open focus->datepicker#open"
                  >
                  <button type="button" class="absolute inset-y-0 right-0 flex items-center pr-4 text-slate-400 dark:text-slate-500" data-action="click->datepicker#open">
                    <i data-lucide="calendar-days" class="h-4 w-4"></i>
                  </button>
                </div>
              </div>
            </div>

            <div class="flex justify-between items-center pt-2">
              <%= link_to "Löschen", camp_path(@camp),
                data: { turbo_method: :delete, turbo_confirm: "Möchtest du dieses Camp wirklich löschen?" },
                class: "inline-flex rounded-lg border border-red-300 px-4 py-2 text-sm font-medium text-red-600 transition hover:bg-red-50 dark:border-red-700 dark:text-red-400 dark:hover:bg-red-950" %>

              <div class="flex gap-3">
                <%= link_to "Abbrechen", admin_camps_path, class: "inline-flex rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-200 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-700" %>
                <%= f.submit "Speichern", class: "inline-flex rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700" %>
              </div>
            </div>

          <% end %>
        </div>

      </div>

    </div>
  <% end %>
</div>
