<div class="space-y-8">

  <div>
    <h2 class="text-2xl font-bold">Dashboard</h2>
    <p class="text-slate-600 dark:text-slate-300 mt-1">
      Willkommen im Lightcamp HQ.
    </p>
    <br>
    <% unless current_user.profile_complete? %>
      <div class="rounded-lg border border-amber-300 bg-amber-50 px-4 py-3 text-amber-900 dark:border-amber-700 dark:bg-amber-950 dark:text-amber-200">
        <p class="font-semibold">Dein Profil ist noch nicht vollständig.</p>
        <p class="mt-1 text-sm">
          Bitte vervollständige dein Profil, bevor du dich für ein Camp anmelden kannst.
        </p>
        <div class="mt-3">
          <%= link_to "Profil vervollständigen", profile_path, class: "inline-flex rounded-lg bg-amber-500 px-4 py-2 text-sm font-medium text-white hover:bg-amber-600" %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="bg-white dark:bg-slate-800 shadow rounded-lg shadow p-6">
    <h3 class="text-lg font-semibold mb-4">Meine Camps</h3>

    <p class="text-slate-500 dark:text-slate-300">
      Du bist aktuell noch keinem Camp zugewiesen.
    </p>
  </div>

</div>