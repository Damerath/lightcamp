<div class="space-y-6">
  <div>
    <h2 class="text-2xl font-bold">Years</h2>
  </div>

  <div class="rounded-lg bg-white dark:bg-slate-800 shadow divide-y divide-slate-200 dark:divide-slate-700">
    <% @years.each do |year| %>
      <div class="px-5 py-3 text-slate-900 dark:text-slate-100">
        <%= year.name %>
      </div>
    <% end %>
  </div>
</div>